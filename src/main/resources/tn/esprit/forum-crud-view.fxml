<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListCell?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ForumCrudController"
            style="-fx-background-color: #f0f2f5;">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1a73e8; -fx-padding: 14 20 14 20;">
            <Label text="💬 Forum"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text=""
                   style="-fx-text-fill: #cce0ff; -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <!-- ── MAIN SPLIT ── -->
    <center>
        <SplitPane dividerPositions="0.32"
                   style="-fx-background-color: transparent; -fx-padding: 0;">

            <!-- ════ LEFT PANEL — Post list + new post ════ -->
            <VBox spacing="0"
                  style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">

                <!-- New Post Form -->
                <VBox spacing="8"
                      style="-fx-padding: 16; -fx-background-color: #f8f9ff;
                             -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                    <Label text="New Post"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="newPostTitleField"
                               promptText="Title…"
                               style="-fx-font-size: 13px;"/>
                    <TextField fx:id="newPostTopicField"
                               promptText="Topic  (e.g. General, Tech…)"
                               style="-fx-font-size: 12px;"/>
                    <TextArea fx:id="newPostContentArea"
                              promptText="What's on your mind?"
                              prefRowCount="3" wrapText="true"
                              style="-fx-font-size: 12px;"/>
                    <Button text="Post"
                            onAction="#handleCreatePost"
                            maxWidth="Infinity"
                            style="-fx-background-color: #1a73e8; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-cursor: hand;
                                   -fx-background-radius: 6;"/>
                </VBox>

                <!-- Post List -->
                <Label text="All Posts"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #666;
                              -fx-padding: 10 16 6 16;"/>
                <ListView fx:id="postListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-border-width: 0;"/>
            </VBox>

            <!-- ════ RIGHT PANEL — Post detail + replies ════ -->
            <VBox spacing="0" style="-fx-background-color: #f0f2f5;">

                <!-- Post Detail Card -->
                <VBox fx:id="postDetailPane" spacing="6"
                      style="-fx-background-color: white; -fx-padding: 20;
                             -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="postTitleLabel" text="Select a post to read it"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #222;
                                      -fx-wrap-text: true;"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="deletePostBtn" text="🗑 Delete"
                                onAction="#handleDeletePost"
                                visible="false"
                                style="-fx-background-color: #fff0f0; -fx-text-fill: #c00;
                                       -fx-border-color: #f5c6c6; -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label fx:id="postTopicLabel" text=""
                               style="-fx-background-color: #e8f0fe; -fx-text-fill: #1a73e8;
                                      -fx-padding: 2 8 2 8; -fx-background-radius: 10;
                                      -fx-font-size: 11px;"/>
                        <Label fx:id="postMetaLabel" text=""
                               style="-fx-text-fill: #999; -fx-font-size: 11px;"/>
                    </HBox>
                    <Label fx:id="postContentLabel" text=""
                           style="-fx-font-size: 13px; -fx-text-fill: #444; -fx-wrap-text: true;"
                           wrapText="true" maxWidth="Infinity"/>
                </VBox>

                <!-- Replies -->
                <ScrollPane fx:id="repliesScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;
                                   -fx-border-width: 0;">
                    <VBox fx:id="repliesContainer" spacing="8"
                          style="-fx-padding: 16; -fx-background-color: transparent;">
                        <Label fx:id="repliesPlaceholder" text="No replies yet."
                               style="-fx-text-fill: #aaa; -fx-font-size: 13px; -fx-padding: 10 0 0 0;"/>
                    </VBox>
                </ScrollPane>

                <!-- Reply Input -->
                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-padding: 14 20 14 20;
                             -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
                    <Label text="Write a reply"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <HBox spacing="8" alignment="CENTER">
                        <TextArea fx:id="replyContentArea"
                                  promptText="Your reply…"
                                  prefRowCount="2" wrapText="true"
                                  style="-fx-font-size: 13px;"
                                  HBox.hgrow="ALWAYS"/>
                        <Button text="Reply ➤"
                                onAction="#handleSubmitReply"
                                style="-fx-background-color: #1a73e8; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-cursor: hand;
                                       -fx-background-radius: 6; -fx-min-width: 80px;
                                       -fx-min-height: 60px;"/>
                    </HBox>
                </VBox>

            </VBox>
        </SplitPane>
    </center>
</BorderPane>
