<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.forum.AdminPostManagementController"
            stylesheets="@forum.css"
            styleClass="root-alt">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="toolbar-card">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <Button text="Back to Posts" onAction="#handleBack"
                    styleClass="secondary-button"/>
            <VBox spacing="3">
                <Label text="Admin Post Management"
                       styleClass="page-title"/>
                <Label text="Review all forum posts and remove any post when needed."
                       styleClass="page-subtitle"/>
                <Label fx:id="currentUserLabel"
                       styleClass="section-title"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh"
                    styleClass="primary-button"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="front-scroll-pane">
            <content>
                <VBox fx:id="postsContainer" spacing="16" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="28" right="48" bottom="48" left="48"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>