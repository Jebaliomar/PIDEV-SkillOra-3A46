<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.forum.AdminPostManagementController"
            stylesheets="@forum.css"
            prefWidth="1440" prefHeight="900" styleClass="root-bg">

    <left>
        <fx:include fx:id="adminSidebar" source="../../../viewsadmin/common/AdminSidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" pannable="true"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="18" styleClass="main-content-wrap">
                    <padding>
                        <Insets top="22" right="24" bottom="20" left="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Community Posts" styleClass="page-title"/>
                            <Label text="Monitor and manage all community discussions." styleClass="page-subtitle"/>
                        </VBox>

                        <Button fx:id="viewCommunityButton" text="View Community" onAction="#handleShowPosts" styleClass="btn-primary"/>
                        <Button fx:id="reportsButton" text="Reports" onAction="#handleShowReports" styleClass="btn-secondary"/>
                    </HBox>

                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <VBox spacing="8" GridPane.columnIndex="0"
                            style="-fx-background-color: rgba(255,255,255,0.60); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.76); -fx-border-radius: 20; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.12, 0, 6); -fx-padding: 16;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" prefWidth="56" prefHeight="56"
                                     style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 18;">
                                    <Label text="📄" style="-fx-font-size: 22px;"/>
                                </VBox>
                                <Label text="TOTAL"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="totalPostsLabel" text="0"
                                style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            <Label text="Community Posts"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1"
                            style="-fx-background-color: rgba(255,255,255,0.60); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.76); -fx-border-radius: 20; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.12, 0, 6); -fx-padding: 16;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" prefWidth="56" prefHeight="56"
                                     style="-fx-background-color: linear-gradient(to bottom right, #f59e0b, #f97316); -fx-background-radius: 18;">
                                    <Label text="!" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Label text="FLAGGED"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="flaggedPostsLabel" text="0"
                                style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            <Label text="Pending Reports"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="2"
                            style="-fx-background-color: rgba(255,255,255,0.60); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.76); -fx-border-radius: 20; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.12, 0, 6); -fx-padding: 16;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" prefWidth="56" prefHeight="56"
                                     style="-fx-background-color: linear-gradient(to bottom right, #34d399, #10b981); -fx-background-radius: 18;">
                                    <Label text="💬" style="-fx-font-size: 20px;"/>
                                </VBox>
                                <Label text="ACTIVE"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="activePostsLabel" text="0"
                                style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            <Label text="With Replies"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="3"
                            style="-fx-background-color: rgba(255,255,255,0.60); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.76); -fx-border-radius: 20; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.12, 0, 6); -fx-padding: 16;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" prefWidth="56" prefHeight="56"
                                     style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f1f5f9); -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-border-width: 1;">
                                    <Label text="1/1" style="-fx-text-fill: #0f172a; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Label text="PAGES"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="pageInfoLabel" text="1/1"
                                style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            <Label text="Current Page"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                    </GridPane>

                      <VBox spacing="0"
                          style="-fx-background-color: rgba(255,255,255,0.62); -fx-background-radius: 22; -fx-border-color: rgba(255,255,255,0.78); -fx-border-radius: 22; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.09), 24, 0.12, 0, 8);">
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 22 24 18 24; -fx-border-color: transparent transparent #e5eaf2 transparent; -fx-border-width: 0 0 1 0;">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="contentSectionTitleLabel" text="All Posts"
                                       style="-fx-text-fill: #0f172a; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                                <Label fx:id="contentSectionSubtitleLabel" text="Showing your moderation feed"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            </VBox>

                            <Label fx:id="postCountLabel" text=""
                                   style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                        </HBox>

                           <Label fx:id="contentHintLabel" text="Use the card actions to open details or remove problematic posts quickly."
                               style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 12 24 8 24;"/>

                           <VBox fx:id="postsContainer" spacing="12" style="-fx-padding: 10 12 14 12;"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
