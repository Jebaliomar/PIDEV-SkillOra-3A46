<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.forum.PostOverviewController"
            style="-fx-background-color: #f0f4f9;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: transparent transparent #e2e8f0 transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <VBox spacing="3">
                <Label text="Community Forum"
                       style="-fx-text-fill: #0f172a; -fx-font-weight: 700;">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Label text="Browse posts and open one to see details and replies."
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                <Label fx:id="currentUserLabel"
                       style="-fx-text-fill: #3b82f6; -fx-font-weight: 700; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Create Post" onAction="#handleCreatePost"
                    style="-fx-background-color: #3b82f6;
                           -fx-text-fill: white;
                           -fx-font-weight: 700;
                           -fx-font-size: 14px;
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-cursor: hand;
                           -fx-padding: 10 20 10 20;
                           -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 10, 0, 0, 3);"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18">
            <padding>
                <Insets top="22" right="32" bottom="24" left="32"/>
            </padding>
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-background-radius: 14;
                         -fx-border-color: #e2e8f0;
                         -fx-border-radius: 14;
                         -fx-padding: 16;">
                <TextField fx:id="searchField"
                           promptText="Search by title, topic, or content..."
                           onAction="#handleSearch"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 10; -fx-border-radius: 10;"/>
                <ComboBox fx:id="typeFilterComboBox"
                          onAction="#handleSearch"
                          prefWidth="160"/>
                <ComboBox fx:id="topicFilterComboBox"
                          onAction="#handleSearch"
                          prefWidth="180"/>
                <Button text="Search" onAction="#handleSearch"
                        style="-fx-background-color: #0f172a;
                               -fx-text-fill: white;
                               -fx-font-weight: 700;
                               -fx-background-radius: 10;
                               -fx-padding: 10 16 10 16;"/>
                <Button text="Reset" onAction="#handleResetFilters"
                        style="-fx-background-color: #e2e8f0;
                               -fx-text-fill: #0f172a;
                               -fx-font-weight: 700;
                               -fx-background-radius: 10;
                               -fx-padding: 10 16 10 16;"/>
            </HBox>
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="postsContainer" spacing="14" alignment="TOP_CENTER">
                        <padding>
                            <Insets top="6" right="8" bottom="8" left="8"/>
                        </padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
