<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.forum.CreatePostController"
            style="-fx-background-color: #f0f4f9;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: transparent transparent #e2e8f0 transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>
            <Button text="← Back to Posts" onAction="#handleBack"
                    style="-fx-background-color: #f1f5f9;
                           -fx-text-fill: #475569;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 8;
                           -fx-border-radius: 8;
                           -fx-cursor: hand;
                           -fx-padding: 8 16 8 16;
                           -fx-border-color: #e2e8f0;
                           -fx-border-width: 1;"/>
            <VBox spacing="3">
                <Label text="Create Post"
                       style="-fx-text-fill: #0f172a; -fx-font-weight: 700;">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Label text="Share your thoughts with the community."
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                <Label fx:id="currentUserLabel"
                       style="-fx-text-fill: #3b82f6; -fx-font-weight: 700; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <content>
                <VBox spacing="0" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="32" right="40" bottom="40" left="40"/>
                    </padding>
                    <VBox spacing="20" maxWidth="680"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-border-color: #e2e8f0;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 16, 0, 0, 4);">
                        <padding>
                            <Insets top="28" right="28" bottom="28" left="28"/>
                        </padding>

                        <!-- Type Field -->
                        <VBox spacing="7">
                            <Label text="Post Type"
                                   style="-fx-text-fill: #374151; -fx-font-weight: 600; -fx-font-size: 13px;"/>
                            <TextField fx:id="typeField" promptText="e.g. Discussion, Question, Announcement"
                                       style="-fx-background-color: #f8fafc;
                                              -fx-border-color: #e2e8f0;
                                              -fx-border-radius: 9;
                                              -fx-background-radius: 9;
                                              -fx-border-width: 1.5;
                                              -fx-padding: 10 14 10 14;
                                              -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b;
                                              -fx-prompt-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Title Field -->
                        <VBox spacing="7">
                            <Label text="Title"
                                   style="-fx-text-fill: #374151; -fx-font-weight: 600; -fx-font-size: 13px;"/>
                            <TextField fx:id="titleField" promptText="Give your post a clear, descriptive title"
                                       style="-fx-background-color: #f8fafc;
                                              -fx-border-color: #e2e8f0;
                                              -fx-border-radius: 9;
                                              -fx-background-radius: 9;
                                              -fx-border-width: 1.5;
                                              -fx-padding: 10 14 10 14;
                                              -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b;
                                              -fx-prompt-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Topic Field -->
                        <VBox spacing="7">
                            <Label text="Topic"
                                   style="-fx-text-fill: #374151; -fx-font-weight: 600; -fx-font-size: 13px;"/>
                            <TextField fx:id="topicField" promptText="Tag a topic area (e.g. Technology, Health)"
                                       style="-fx-background-color: #f8fafc;
                                              -fx-border-color: #e2e8f0;
                                              -fx-border-radius: 9;
                                              -fx-background-radius: 9;
                                              -fx-border-width: 1.5;
                                              -fx-padding: 10 14 10 14;
                                              -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b;
                                              -fx-prompt-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Content Field -->
                        <VBox spacing="7">
                            <Label text="Content"
                                   style="-fx-text-fill: #374151; -fx-font-weight: 600; -fx-font-size: 13px;"/>
                            <TextArea fx:id="contentArea" promptText="Write your post content here..." prefRowCount="8"
                                      style="-fx-background-color: #f8fafc;
                                             -fx-border-color: #e2e8f0;
                                             -fx-border-radius: 9;
                                             -fx-background-radius: 9;
                                             -fx-border-width: 1.5;
                                             -fx-padding: 10 14 10 14;
                                             -fx-font-size: 14px;
                                             -fx-text-fill: #1e293b;
                                             -fx-prompt-text-fill: #94a3b8;"/>
                        </VBox>

                        <Label fx:id="postErrorLabel" managed="false" visible="false" wrapText="true"
                               style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: 600;"/>

                        <!-- Divider -->
                        <Region style="-fx-background-color: #f1f5f9; -fx-pref-height: 1; -fx-max-height: 1;"/>

                        <!-- Action row -->
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Publish Post" onAction="#handleSavePost"
                                    style="-fx-background-color: #3b82f6;
                                           -fx-text-fill: white;
                                           -fx-font-weight: 700;
                                           -fx-font-size: 14px;
                                           -fx-background-radius: 10;
                                           -fx-border-radius: 10;
                                           -fx-cursor: hand;
                                           -fx-padding: 11 28 11 28;
                                           -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 10, 0, 0, 3);"/>
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
