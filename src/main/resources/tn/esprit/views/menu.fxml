<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.MenuController"
      alignment="CENTER" spacing="28.0"
      style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #e2e8f0);">
    <padding>
        <Insets top="40.0" right="30.0" bottom="40.0" left="30.0"/>
    </padding>

    <Label text="SkillOra Back Office"
           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
    <Label text="Choose the page you want to open"
           style="-fx-font-size: 16px; -fx-text-fill: #334155;"/>

    <HBox spacing="18.0" alignment="CENTER">
        <Button text="Availability Slots"
                onAction="#openSlots"
                prefWidth="230.0"
                prefHeight="54.0"
                style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #0ea5e9; -fx-text-fill: white;"/>
        <Button text="RendezVous"
                onAction="#openRendezVous"
                prefWidth="230.0"
                prefHeight="54.0"
                style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #10b981; -fx-text-fill: white;"/>
    </HBox>
</VBox>
