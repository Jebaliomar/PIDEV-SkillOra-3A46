<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.availabilityslot.AvailabilitySlotController"
            style="-fx-background-color: linear-gradient(to bottom, #010a24, #020f38);">

    <top>
        <VBox spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="14.0" right="16.0" bottom="8.0" left="16.0" />
            </padding>

            <HBox spacing="12.0" style="-fx-background-color: #0d1732; -fx-border-color: #1b2a4d; -fx-border-width: 0 0 1 0; -fx-padding: 10 14;">
                <Label text="⚓ SkillHarbor" style="-fx-text-fill: #e2e8f0; -fx-font-size: 28px; -fx-font-weight: 800;" />
                <Button mnemonicParsing="false" onAction="#goToEvents" text="Events"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15px; -fx-font-weight: 700;" />
                <Button mnemonicParsing="false" onAction="#goToRendezVous" text="Rendez-vous"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-font-size: 15px; -fx-font-weight: 700;" />
                <Button mnemonicParsing="false" onAction="#goToSlots" text="Slots"
                        style="-fx-background-color: #1f3b70; -fx-background-radius: 12; -fx-text-fill: #60a5fa; -fx-font-size: 15px; -fx-font-weight: 700;" />
            </HBox>

            <VBox spacing="8.0" style="-fx-background-color: linear-gradient(to right, #172554, #0b2f8a); -fx-background-radius: 18; -fx-padding: 24;">
                <Label text="Calendrier des créneaux"
                       style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #e2e8f0;" />
                <Label text="Affichage mensuel des créneaux disponibles (vert) et réservés (rouge)."
                       style="-fx-font-size: 14px; -fx-text-fill: #bfdbfe;" />
            </VBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="8.0" right="16.0" bottom="10.0" left="16.0" />
            </padding>
            <WebView fx:id="calendarWebView" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10.0" style="-fx-padding: 10 16 14 16;">
            <Button mnemonicParsing="false" onAction="#refreshCalendar" text="Refresh"
                    style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-font-weight: 700; -fx-background-radius: 10;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #93c5fd; -fx-font-size: 13px;" />
        </HBox>
    </bottom>
</BorderPane>
