<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.auth.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #020718, #0f1b38);">

    <top>
        <HBox style="-fx-background-color: #0b1734; -fx-border-color: #182b54; -fx-border-width: 0 0 1 0; -fx-padding: 14 18;">
            <Label text="⚓ SkillHarbor" style="-fx-text-fill: #e2e8f0; -fx-font-size: 28px; -fx-font-weight: 800;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-alignment: center;">
            <VBox spacing="16" style="-fx-background-color: #081a42; -fx-border-color: #173467; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 28; -fx-max-width: 520;">
                <Label text="Connexion" style="-fx-text-fill: #e2e8f0; -fx-font-size: 34px; -fx-font-weight: 800;" />
                <Label text="Connectez-vous pour accéder à votre espace professeur ou étudiant."
                       style="-fx-text-fill: #93c5fd; -fx-font-size: 14px; -fx-wrap-text: true;" />

                <VBox spacing="8">
                    <Label text="Email ou Username" style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: 700;" />
                    <TextField fx:id="identifierField"
                               promptText="ex: professeur@skillora.com"
                               onAction="#handleLogin"
                               style="-fx-background-color: #101f40; -fx-border-color: #2754a3; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #94a3b8; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="8">
                    <Label text="Mot de passe" style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: 700;" />
                    <PasswordField fx:id="passwordField"
                                   promptText="********"
                                   onAction="#handleLogin"
                                   style="-fx-background-color: #101f40; -fx-border-color: #2754a3; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #94a3b8; -fx-font-size: 14px;" />
                </VBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #fca5a5; -fx-font-size: 13px;" />

                <HBox spacing="10">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Effacer" onAction="#handleClear"
                            style="-fx-background-color: #1f2f57; -fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 10;" />
                    <Button text="Se connecter" onAction="#handleLogin"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 10;" />
                </HBox>
            </VBox>
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </VBox>
    </center>
</BorderPane>
