<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.rendezvous.RendezVousController"
            stylesheets="@../theme/skillora-pro.css"
            styleClass="app-root">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="14.0">
                    <padding>
                        <Insets top="16.0" right="18.0" bottom="12.0" left="18.0" />
                    </padding>

                    <VBox spacing="8.0" styleClass="hero-panel">
                        <Label text="Mes Rendez-vous"
                               styleClass="hero-title" />
                        <Label text="Consultez, modifiez et gérez vos rendez-vous."
                               styleClass="hero-subtitle" />
                    </VBox>

                    <HBox spacing="10.0" styleClass="filter-bar">
                        <Label text="Filtrer:" styleClass="label-soft" />
                        <Button fx:id="filterAllBtn" onAction="#setFilterAll" text="Tous (0)"
                                styleClass="btn-secondary" />
                        <Button fx:id="filterPendingBtn" onAction="#setFilterPending" text="En attente (0)"
                                styleClass="btn-secondary" />
                        <Button fx:id="filterConfirmedBtn" onAction="#setFilterConfirmed" text="Confirmés (0)"
                                styleClass="btn-secondary" />
                        <Button fx:id="filterRefusedBtn" onAction="#setFilterRefused" text="Refusés (0)"
                                styleClass="btn-secondary" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" promptText="Rechercher rendez-vous..."
                                   prefWidth="300.0"
                                   styleClass="text-field app-search" />
                        <Button mnemonicParsing="false" onAction="#goToSlotsCalendar" text="Voir les créneaux"
                                styleClass="btn-ghost" />
                        <Button fx:id="createTopBtn" mnemonicParsing="false" onAction="#handleCreate" text="Nouveau rendez-vous"
                                styleClass="btn-primary" />
                    </HBox>

                    <VBox spacing="10.0">
                        <Label text="Cards des Rendez-vous" styleClass="section-title" />
                        <GridPane fx:id="cardsContainer" hgap="12.0" vgap="12.0" styleClass="cards-container" />
                    </VBox>

                    <HBox spacing="10.0" styleClass="footer-shell">
                        <Label text="Par page" styleClass="label-soft" />
                        <ComboBox fx:id="pageSizeCombo" prefWidth="84.0" />
                        <Pagination fx:id="rendezVousPagination" maxPageIndicatorCount="8" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="statusLabel" text="Ready" styleClass="status-text" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
