<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.ResetPasswordController"
      prefWidth="1000" prefHeight="620" styleClass="split-container">

    <VBox HBox.hgrow="ALWAYS" styleClass="left-panel" spacing="0" alignment="TOP_LEFT">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <StackPane styleClass="logo-box">
                <Label text="S" styleClass="logo-icon"/>
            </StackPane>
            <Label text="SkillORA" styleClass="logo-text"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox alignment="CENTER_LEFT" spacing="6" maxWidth="400">
            <padding><Insets left="20"/></padding>

            <Label text="Reset password" styleClass="page-title"/>
            <Label text="Enter the code we sent you and choose a new password." styleClass="page-subtitle" wrapText="true"/>

            <Region prefHeight="18"/>

            <HBox fx:id="errorBox" styleClass="error-box" spacing="8" managed="false" visible="false" alignment="CENTER_LEFT">
                <Label text="!" style="-fx-font-weight:bold; -fx-text-fill:#DC2626; -fx-font-size:16;"/>
                <VBox spacing="2">
                    <Label text="Reset failed" styleClass="error-title"/>
                    <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
                </VBox>
            </HBox>

            <HBox fx:id="successBox" styleClass="error-box" spacing="8" managed="false" visible="false" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(34,197,94,0.12); -fx-border-color: #22c55e;">
                <Label text="OK" style="-fx-font-weight:bold; -fx-text-fill:#16a34a; -fx-font-size:14;"/>
                <Label fx:id="successLabel" style="-fx-text-fill:#16a34a;" wrapText="true"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Email" styleClass="input-label"/>
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="custom-text-field" prefHeight="42"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Reset code" styleClass="input-label"/>
                <TextField fx:id="codeField" promptText="6-digit code" styleClass="custom-text-field" prefHeight="42"/>
            </VBox>

            <VBox spacing="6">
                <Label text="New password" styleClass="input-label"/>
                <PasswordField fx:id="newPasswordField" promptText="At least 6 characters" styleClass="password-field" prefHeight="42"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Confirm new password" styleClass="input-label"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password" styleClass="password-field" prefHeight="42"/>
            </VBox>

            <Region prefHeight="8"/>

            <Button fx:id="resetBtn" text="Reset password" onAction="#handleReset" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44"/>

            <Region prefHeight="12"/>

            <HBox alignment="CENTER" spacing="4">
                <Hyperlink text="Back to sign in" onAction="#goBackToLogin" styleClass="link-button"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox alignment="CENTER">
            <Label text="Codes expire after 15 minutes" styleClass="footer-text"/>
        </HBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" styleClass="right-panel" alignment="CENTER" spacing="20">
        <StackPane>
            <Circle radius="120" styleClass="decorative-circle"/>
            <Circle radius="80" style="-fx-fill: linear-gradient(to bottom right, #22d3ee, #7C3AED); -fx-opacity: 0.1;"/>
            <VBox alignment="CENTER" spacing="16" maxWidth="320">
                <Label text="Choose a Strong Password" styleClass="right-panel-title" wrapText="true"/>
                <Label text="Mix letters, numbers and symbols to keep your account safe." styleClass="right-panel-subtitle" wrapText="true"/>
            </VBox>
        </StackPane>
    </VBox>
</HBox>
