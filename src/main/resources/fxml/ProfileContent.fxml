<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane pf-scroll"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ProfileController">
    <VBox styleClass="pf-root" spacing="0">
        <padding><Insets top="56" right="96" bottom="88" left="96"/></padding>

        <!-- Eyebrow -->
        <HBox alignment="CENTER_LEFT" spacing="18">
            <Label text="PROFILE" styleClass="pf-eyebrow"/>
            <Region styleClass="pf-eyebrow-rule" prefHeight="1" maxHeight="1" HBox.hgrow="ALWAYS"/>
            <Label text="N° 001" styleClass="pf-eyebrow"/>
            <Region styleClass="pf-eyebrow-rule" prefHeight="1" maxHeight="1" prefWidth="80" maxWidth="80"/>
            <Label text="SKILLORA — STUDENT RECORD" styleClass="pf-eyebrow"/>
        </HBox>

        <Region prefHeight="56"/>

        <!-- Hero: asymmetric — avatar left, massive serif name right -->
        <HBox spacing="64" alignment="TOP_LEFT">
            <VBox spacing="18" alignment="TOP_LEFT">
                <StackPane fx:id="avatarHolder" prefWidth="200" prefHeight="240"
                           minWidth="200" minHeight="240" styleClass="pf-avatar-frame">
                    <Circle fx:id="avatarRing" radius="78" styleClass="pf-avatar-ring"/>
                    <Label fx:id="avatarInitials" styleClass="pf-avatar-initials"/>
                </StackPane>
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="roleBadge" text="Student" styleClass="pf-role"/>
                </HBox>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="18">
                <padding><Insets top="6"/></padding>
                <Label fx:id="fullNameLabel" text="Full Name" styleClass="pf-name" wrapText="true"/>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Region styleClass="pf-accent-mark" prefWidth="32" prefHeight="2"
                            maxWidth="32" maxHeight="2" minHeight="2"/>
                    <Label fx:id="fieldLabel" text="Field of study" styleClass="pf-field"/>
                </HBox>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label fx:id="universityLabel" text="University" styleClass="pf-origin"/>
                    <Label text="·" styleClass="pf-origin"/>
                    <Label fx:id="countryLabel" text="Country" styleClass="pf-origin"/>
                </HBox>
                <Region prefHeight="14"/>
                <HBox alignment="CENTER_LEFT">
                    <Button text="EDIT PROFILE" onAction="#goToSettings" styleClass="pf-btn"/>
                </HBox>
            </VBox>
        </HBox>

        <Region prefHeight="80"/>
        <Region styleClass="pf-rule" prefHeight="1" maxHeight="1"/>
        <Region prefHeight="56"/>

        <!-- Index ledger + pull quote about -->
        <HBox spacing="96" alignment="TOP_LEFT">
            <VBox spacing="0" prefWidth="360" minWidth="360">
                <Label text="I. INDEX" styleClass="pf-section-label"/>
                <Region prefHeight="24"/>

                <HBox styleClass="pf-ledger-row" alignment="CENTER_LEFT" spacing="24">
                    <Label text="01" styleClass="pf-ledger-num"/>
                    <Label text="Courses" styleClass="pf-ledger-key"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="12" styleClass="pf-ledger-val"/>
                </HBox>
                <Region styleClass="pf-hairline" prefHeight="1" maxHeight="1"/>

                <HBox styleClass="pf-ledger-row" alignment="CENTER_LEFT" spacing="24">
                    <Label text="02" styleClass="pf-ledger-num"/>
                    <Label text="Hours studied" styleClass="pf-ledger-key"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="84" styleClass="pf-ledger-val"/>
                </HBox>
                <Region styleClass="pf-hairline" prefHeight="1" maxHeight="1"/>

                <HBox styleClass="pf-ledger-row" alignment="CENTER_LEFT" spacing="24">
                    <Label text="03" styleClass="pf-ledger-num"/>
                    <Label text="Certificates" styleClass="pf-ledger-key"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="5" styleClass="pf-ledger-val"/>
                </HBox>
                <Region styleClass="pf-hairline" prefHeight="1" maxHeight="1"/>

                <HBox styleClass="pf-ledger-row" alignment="CENTER_LEFT" spacing="24">
                    <Label text="04" styleClass="pf-ledger-num"/>
                    <Label text="Badges" styleClass="pf-ledger-key"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="8" styleClass="pf-ledger-val"/>
                </HBox>
                <Region styleClass="pf-hairline" prefHeight="1" maxHeight="1"/>

                <Region prefHeight="48"/>

                <Label text="II. STREAK" styleClass="pf-section-label"/>
                <Region prefHeight="10"/>
                <HBox spacing="14" alignment="BASELINE_LEFT">
                    <Label text="7" styleClass="pf-big-num"/>
                    <VBox spacing="2">
                        <padding><Insets bottom="18"/></padding>
                        <Label text="consecutive" styleClass="pf-muted-small"/>
                        <Label text="days of learning" styleClass="pf-muted-small"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="0">
                <Label text="III. ABOUT" styleClass="pf-section-label"/>
                <Region prefHeight="18"/>
                <HBox spacing="20" alignment="TOP_LEFT">
                    <Label text="“" styleClass="pf-quote-mark" translateY="-28.0"/>
                    <Label fx:id="bioLabel" text="No bio yet." styleClass="pf-quote"
                           wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </HBox>

        <Region prefHeight="80"/>
        <Region styleClass="pf-rule" prefHeight="1" maxHeight="1"/>
        <Region prefHeight="44"/>

        <!-- Colophon -->
        <Label text="IV. COLOPHON" styleClass="pf-section-label"/>
        <Region prefHeight="24"/>
        <GridPane hgap="56" vgap="20" styleClass="pf-colophon">
            <columnConstraints>
                <ColumnConstraints minWidth="72"/>
                <ColumnConstraints minWidth="240"/>
                <ColumnConstraints minWidth="72"/>
                <ColumnConstraints minWidth="240"/>
            </columnConstraints>
            <Label text="Email"  styleClass="pf-colophon-key" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="emailLabel"        styleClass="pf-colophon-val" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Since"  styleClass="pf-colophon-key" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <Label fx:id="memberSinceLabel"  styleClass="pf-colophon-val" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Phone"  styleClass="pf-colophon-key" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="phoneLabel"        styleClass="pf-colophon-val" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Gender" styleClass="pf-colophon-key" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <Label fx:id="genderLabel"       styleClass="pf-colophon-val" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="Born"   styleClass="pf-colophon-key" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="dobLabel"          styleClass="pf-colophon-val" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        </GridPane>

        <Region prefHeight="64"/>
        <Region styleClass="pf-rule" prefHeight="1" maxHeight="1"/>
        <Region prefHeight="44"/>

        <!-- Chapters + Proficiencies -->
        <HBox spacing="96" alignment="TOP_LEFT">
            <VBox HBox.hgrow="ALWAYS" spacing="22">
                <Label text="V. CHAPTERS" styleClass="pf-section-label"/>
                <FlowPane hgap="10" vgap="10">
                    <Label text="First Course" styleClass="pf-tag"/>
                    <Label text="Fast Learner" styleClass="pf-tag"/>
                    <Label text="On Fire"     styleClass="pf-tag"/>
                    <Label text="Top 10%"     styleClass="pf-tag"/>
                </FlowPane>
            </VBox>

            <VBox prefWidth="420" minWidth="420" spacing="22">
                <Label text="VI. PROFICIENCIES" styleClass="pf-section-label"/>
                <VBox spacing="18">
                    <VBox spacing="8">
                        <HBox alignment="BASELINE_LEFT">
                            <Label text="JavaScript" styleClass="pf-skill-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="85" styleClass="pf-skill-val"/>
                        </HBox>
                        <ProgressBar progress="0.85" styleClass="pf-skill-bar" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="8">
                        <HBox alignment="BASELINE_LEFT">
                            <Label text="Python" styleClass="pf-skill-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="70" styleClass="pf-skill-val"/>
                        </HBox>
                        <ProgressBar progress="0.7" styleClass="pf-skill-bar" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="8">
                        <HBox alignment="BASELINE_LEFT">
                            <Label text="UI / UX" styleClass="pf-skill-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="60" styleClass="pf-skill-val"/>
                        </HBox>
                        <ProgressBar progress="0.6" styleClass="pf-skill-bar" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

    </VBox>
</ScrollPane>
