<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.ForgotPasswordController"
      prefWidth="1000" prefHeight="620" styleClass="split-container">

    <VBox HBox.hgrow="ALWAYS" styleClass="left-panel" spacing="0" alignment="TOP_LEFT">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <StackPane styleClass="logo-box">
                <Label text="S" styleClass="logo-icon"/>
            </StackPane>
            <Label text="SkillORA" styleClass="logo-text"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox alignment="CENTER_LEFT" spacing="6" maxWidth="380">
            <padding><Insets left="20"/></padding>

            <Label text="Forgot password?" styleClass="page-title"/>
            <Label text="Enter your email and we'll send you a reset code." styleClass="page-subtitle" wrapText="true"/>

            <Region prefHeight="24"/>

            <HBox fx:id="errorBox" styleClass="error-box" spacing="8" managed="false" visible="false" alignment="CENTER_LEFT">
                <Label text="!" style="-fx-font-weight:bold; -fx-text-fill:#DC2626; -fx-font-size:16;"/>
                <VBox spacing="2">
                    <Label text="Something's wrong" styleClass="error-title"/>
                    <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Email" styleClass="input-label"/>
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="custom-text-field" prefHeight="42"/>
            </VBox>

            <Region prefHeight="8"/>

            <Button fx:id="sendBtn" text="Send reset code" onAction="#handleSend" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44"/>

            <Region prefHeight="16"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Remembered your password?" styleClass="link-text"/>
                <Hyperlink text="Back to sign in" onAction="#goBackToLogin" styleClass="link-button"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox alignment="CENTER">
            <Label text="We'll email a 6-digit code valid for 15 minutes" styleClass="footer-text"/>
        </HBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" styleClass="right-panel" alignment="CENTER" spacing="20">
        <StackPane>
            <Circle radius="120" styleClass="decorative-circle"/>
            <Circle radius="80" style="-fx-fill: linear-gradient(to bottom right, #22d3ee, #7C3AED); -fx-opacity: 0.1;"/>
            <VBox alignment="CENTER" spacing="16" maxWidth="320">
                <Label text="Recover Access Securely" styleClass="right-panel-title" wrapText="true"/>
                <Label text="We'll send a one-time code to your email so you can get back to learning." styleClass="right-panel-subtitle" wrapText="true"/>
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" style="-fx-fill: #0891b2; -fx-opacity: 0.8;"/>
            <Circle radius="4" style="-fx-fill: #22d3ee; -fx-opacity: 0.5;"/>
            <Circle radius="4" style="-fx-fill: #7C3AED; -fx-opacity: 0.3;"/>
        </HBox>
    </VBox>
</HBox>
