<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AdminPanelController"
            prefWidth="1200" prefHeight="750" styleClass="root-bg">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="270" styleClass="admin-sidebar" spacing="0">
            <padding><Insets top="20" bottom="20" left="16" right="16"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand-box">
                <StackPane styleClass="brand-icon-wrap" prefWidth="42" prefHeight="42">
                    <Label text="S" styleClass="brand-icon"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="SkillORA" styleClass="brand-title"/>
                    <Label text="Admin Panel" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="30"/>

            <!-- Nav Items -->
            <VBox spacing="8" fx:id="navContainer" styleClass="sidebar-nav-group">
                <Button fx:id="navDashboard" text="Dashboard" onAction="#showDashboard"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navUsers" text="User Management" onAction="#showUserManagement"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navEvents" text="Events" onAction="#showEventsDashboard"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navSalles" text="Salles" onAction="#showSallesDashboard"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navReservations" text="Reservations" onAction="#showReservationsDashboard"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <!-- Forum admin -->
                <Button fx:id="navForum" text="Forum" onAction="#showAdminForum"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navCourses" text="Courses Admin" onAction="#showCoursesAdmin"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
                <Button fx:id="navStats" text="Statistics" onAction="#showStatistics"
                        styleClass="sidebar-nav-item" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="44"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Theme Toggle -->
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme"
                    styleClass="nav-item" alignment="CENTER" prefHeight="40" prefWidth="40"/>

            <Region prefHeight="8"/>

            <!-- Logout -->
            <Button text="   Sign Out" onAction="#handleLogout"
                    styleClass="nav-item-danger" maxWidth="Infinity" alignment="CENTER_LEFT" prefHeight="40"/>
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding><Insets top="0" bottom="0" left="0" right="0"/></padding>
        </StackPane>
    </center>

</BorderPane>
