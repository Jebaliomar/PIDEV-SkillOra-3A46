<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AdminPanelController"
            prefWidth="1200" prefHeight="750" styleClass="root-bg">

    <left>
        <fx:include fx:id="adminSidebar" source="../viewsadmin/common/AdminSidebar.fxml"/>
    </left>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding><Insets top="0" bottom="0" left="0" right="0"/></padding>
        </StackPane>
    </center>

</BorderPane>
