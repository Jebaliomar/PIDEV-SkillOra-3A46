<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ProfessorHomeController">
    <VBox spacing="36">
        <padding><Insets top="40" right="60" bottom="60" left="60"/></padding>

        <!-- Hero -->
        <VBox styleClass="hero-card" spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>
            <Label text="Welcome back, Professor" styleClass="hero-eyebrow"/>
            <Label fx:id="heroTitle" text="Teach. Mentor. Inspire." styleClass="hero-title" wrapText="true"/>
            <Label text="Manage your courses, review student progress, and shape the next generation of learners." styleClass="hero-subtitle" wrapText="true"/>
            <HBox spacing="16">
                <Button text="View My Profile" onAction="#goToProfile" styleClass="btn-primary"/>
                <Button text="Open Settings" onAction="#goToSettings" styleClass="btn-outline"/>
            </HBox>
        </VBox>

        <!-- Quick stats -->
        <HBox spacing="24">
            <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="My Courses" styleClass="metric-label"/>
                <Label text="6" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-green" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="Students" styleClass="metric-label"/>
                <Label text="248" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-purple" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="Lessons" styleClass="metric-label"/>
                <Label text="42" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-orange" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="Avg. Rating" styleClass="metric-label"/>
                <Label text="4.9" styleClass="metric-value"/>
            </VBox>
        </HBox>

        <!-- Teaching focus -->
        <VBox spacing="18">
            <Label text="Teaching Focus" styleClass="dashboard-title"/>
            <Label text="Your most active subject areas this semester" styleClass="dashboard-subtitle"/>
            <FlowPane hgap="18" vgap="18">
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Software Engineering" styleClass="chart-title"/>
                    <Label text="3 courses" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Data Science" styleClass="chart-title"/>
                    <Label text="2 courses" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Web Development" styleClass="chart-title"/>
                    <Label text="1 course" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="Mentoring" styleClass="chart-title"/>
                    <Label text="12 active" styleClass="chart-subtitle"/>
                </VBox>
            </FlowPane>
        </VBox>

        <!-- CTA -->
        <VBox styleClass="cta-card" spacing="12" alignment="CENTER">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            <Label text="Complete your faculty profile" styleClass="hero-title"/>
            <Label text="Import your details from LinkedIn in one click — no manual typing." styleClass="hero-subtitle"/>
            <Button text="Go to Settings" onAction="#goToSettings" styleClass="btn-primary"/>
        </VBox>
    </VBox>
</ScrollPane>
