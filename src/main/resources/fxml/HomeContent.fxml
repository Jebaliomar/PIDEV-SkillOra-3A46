<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.HomeController">
    <VBox spacing="36">
        <padding><Insets top="40" right="60" bottom="60" left="60"/></padding>

        <!-- Hero -->
        <VBox styleClass="hero-card" spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>
            <Label text="%home.welcome" styleClass="hero-eyebrow"/>
            <Label fx:id="heroTitle" text="%home.title" styleClass="hero-title" wrapText="true"/>
            <Label text="%home.subtitle" styleClass="hero-subtitle" wrapText="true"/>
            <HBox spacing="16">
                <Button text="%home.btn.browse" styleClass="btn-primary"/>
                <Button text="%home.btn.profile" onAction="#goToProfile" styleClass="btn-outline"/>
            </HBox>
        </VBox>

        <!-- Quick stats -->
        <HBox spacing="24">
            <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="%home.metric.courses" styleClass="metric-label"/>
                <Label text="10K+" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-green" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="%home.metric.students" styleClass="metric-label"/>
                <Label text="500K+" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-purple" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="%home.metric.instructors" styleClass="metric-label"/>
                <Label text="2K+" styleClass="metric-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-orange" HBox.hgrow="ALWAYS">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="%home.metric.rating" styleClass="metric-label"/>
                <Label text="4.8" styleClass="metric-value"/>
            </VBox>
        </HBox>

        <!-- Featured categories -->
        <VBox spacing="18">
            <Label text="%home.featured" styleClass="dashboard-title"/>
            <Label text="%home.featured.subtitle" styleClass="dashboard-subtitle"/>
            <FlowPane hgap="18" vgap="18">
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.dev" styleClass="chart-title"/>
                    <Label text="1200+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.design" styleClass="chart-title"/>
                    <Label text="850+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.business" styleClass="chart-title"/>
                    <Label text="960+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.marketing" styleClass="chart-title"/>
                    <Label text="720+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.data" styleClass="chart-title"/>
                    <Label text="540+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.photo" styleClass="chart-title"/>
                    <Label text="380+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.music" styleClass="chart-title"/>
                    <Label text="290+" styleClass="chart-subtitle"/>
                </VBox>
                <VBox styleClass="chart-card" prefWidth="220">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="%home.cat.lang" styleClass="chart-title"/>
                    <Label text="410+" styleClass="chart-subtitle"/>
                </VBox>
            </FlowPane>
        </VBox>

        <!-- Testimonial-style CTA -->
        <VBox styleClass="cta-card" spacing="12" alignment="CENTER">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            <Label text="%home.cta.title" styleClass="hero-title"/>
            <Label text="%home.cta.subtitle" styleClass="hero-subtitle"/>
            <Button text="%home.cta.btn" onAction="#goToSettings" styleClass="btn-primary"/>
        </VBox>
    </VBox>
</ScrollPane>
