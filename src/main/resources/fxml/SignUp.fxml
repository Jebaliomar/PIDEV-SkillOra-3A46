<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.SignUpController"
      prefWidth="1000" prefHeight="700" styleClass="split-container">

    <!-- Left Panel - Sign Up Form -->
    <VBox HBox.hgrow="ALWAYS" styleClass="left-panel" spacing="0" alignment="TOP_LEFT">

        <!-- Logo Header + Theme Toggle -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <StackPane styleClass="logo-box">
                <Label text="S" styleClass="logo-icon"/>
            </StackPane>
            <Label text="SkillORA" styleClass="logo-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle"
                    prefWidth="38" prefHeight="38"/>
        </HBox>

        <Region prefHeight="10"/>

        <!-- Scrollable Form Content -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="CENTER_LEFT" spacing="6" maxWidth="420">
                <padding><Insets left="20" right="20" top="10" bottom="20"/></padding>

                <!-- Title -->
                <Label text="Create your account" styleClass="page-title"/>
                <Label text="Join SkillORA and start your journey" styleClass="page-subtitle"/>

                <Region prefHeight="16"/>

                <!-- Error Message -->
                <HBox fx:id="errorBox" styleClass="error-box" spacing="8" managed="false" visible="false" alignment="CENTER_LEFT">
                    <Label text="!" style="-fx-font-weight:bold; -fx-text-fill:#DC2626; -fx-font-size:16;"/>
                    <VBox spacing="2">
                        <Label text="Registration Failed" styleClass="error-title"/>
                        <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- Success Message -->
                <HBox fx:id="successBox" styleClass="success-box" spacing="8" managed="false" visible="false" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-font-weight:bold; -fx-text-fill:#065F46; -fx-font-size:16;"/>
                    <Label fx:id="successLabel" styleClass="success-text" wrapText="true"/>
                </HBox>

                <!-- First Name & Last Name (side by side) -->
                <HBox spacing="12">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="First Name" styleClass="input-label"/>
                        <TextField fx:id="firstNameField" promptText="John" styleClass="custom-text-field" prefHeight="42"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Last Name" styleClass="input-label"/>
                        <TextField fx:id="lastNameField" promptText="Doe" styleClass="custom-text-field" prefHeight="42"/>
                    </VBox>
                </HBox>

                <!-- Email Field -->
                <VBox spacing="6">
                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="you@example.com" styleClass="custom-text-field" prefHeight="42"/>
                </VBox>

                <!-- Password Field -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="input-label"/>
                    <PasswordField fx:id="passwordField" promptText="Min. 8 characters" styleClass="password-field" prefHeight="42"/>
                </VBox>

                <!-- Confirm Password Field -->
                <VBox spacing="6">
                    <Label text="Confirm Password" styleClass="input-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" styleClass="password-field" prefHeight="42"/>
                </VBox>

                <!-- Role Selection -->
                <VBox spacing="8">
                    <Label text="I want to join as" styleClass="input-label"/>
                    <HBox spacing="12">
                        <HBox styleClass="role-container" HBox.hgrow="ALWAYS" spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="studentRadio" text="Student" styleClass="role-radio">
                                <toggleGroup>
                                    <ToggleGroup fx:id="roleGroup"/>
                                </toggleGroup>
                            </RadioButton>
                        </HBox>
                        <HBox styleClass="role-container" HBox.hgrow="ALWAYS" spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="professorRadio" text="Professor" toggleGroup="$roleGroup" styleClass="role-radio"/>
                        </HBox>
                    </HBox>
                </VBox>

                <Region prefHeight="10"/>

                <!-- Face ID (optional) -->
                <VBox spacing="6">
                    <Label text="Face ID (optional)" styleClass="input-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="faceIdBtn" text="Add Face ID" onAction="#handleFaceIdRegister"
                                style="-fx-background-color: linear-gradient(to right, #7c3aed, #22d3ee); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 16 10 16; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Label fx:id="faceIdStatus" text="Not set" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <Region prefHeight="10"/>

                <!-- Sign Up Button -->
                <Button text="Create Account" onAction="#handleSignUp" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44"/>

                <Region prefHeight="12"/>

                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Already have an account?" styleClass="link-text"/>
                    <Hyperlink text="Sign in" fx:id="signInLink" onAction="#goToLogin" styleClass="link-button"/>
                </HBox>

                <Region prefHeight="10"/>
            </VBox>
        </ScrollPane>

        <!-- Footer -->
        <HBox alignment="CENTER">
            <padding><Insets top="8" bottom="8"/></padding>
            <Label text="Secure 256-bit SSL encryption" styleClass="footer-text"/>
        </HBox>
    </VBox>

    <!-- Right Panel - Decorative -->
    <VBox HBox.hgrow="ALWAYS" styleClass="right-panel" alignment="CENTER" spacing="20">
        <StackPane>
            <Circle radius="120" styleClass="decorative-circle"/>
            <Circle radius="80" style="-fx-fill: linear-gradient(to bottom right, #22d3ee, #7C3AED); -fx-opacity: 0.1;"/>
            <VBox alignment="CENTER" spacing="16" maxWidth="320">
                <Label text="Join Our Community" styleClass="right-panel-title" wrapText="true"/>
                <Label text="Create your account and unlock access to courses, mentors, and a global learning network." styleClass="right-panel-subtitle" wrapText="true"/>
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" style="-fx-fill: #0891b2; -fx-opacity: 0.8;"/>
            <Circle radius="4" style="-fx-fill: #22d3ee; -fx-opacity: 0.5;"/>
            <Circle radius="4" style="-fx-fill: #7C3AED; -fx-opacity: 0.3;"/>
        </HBox>
    </VBox>
</HBox>
