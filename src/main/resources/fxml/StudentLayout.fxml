<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.StudentLayoutController"
            styleClass="admin-root" prefWidth="1280" prefHeight="820">

    <top>
        <HBox styleClass="student-header" alignment="CENTER_LEFT" spacing="24">
            <padding><Insets top="16" right="32" bottom="16" left="32"/></padding>

            <Label text="SkillORA" styleClass="logo-text"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Home" onAction="#showHome" fx:id="navHome" styleClass="student-nav-btn"/>
            <Button text="Profile" onAction="#showProfile" fx:id="navProfile" styleClass="student-nav-btn"/>
            <Button text="Settings" onAction="#showSettings" fx:id="navSettings" styleClass="student-nav-btn"/>

            <Region prefWidth="20"/>

            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle"/>
            <Label fx:id="userNameLabel" styleClass="header-username"/>
            <Button text="Sign Out" onAction="#handleLogout" styleClass="btn-outline"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>
</BorderPane>
