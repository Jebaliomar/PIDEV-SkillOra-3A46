<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.StudentLayoutController"
            styleClass="admin-root" prefWidth="1280" prefHeight="820">

    <top>
        <HBox styleClass="student-header" alignment="CENTER_LEFT" spacing="22">
            <padding><Insets top="22" right="48" bottom="22" left="48"/></padding>

            <Label text="%common.brand" styleClass="logo-text"/>
            <Region styleClass="nav-vrule" prefWidth="1" maxWidth="1" prefHeight="24" maxHeight="24"/>
            <Label text="%student.eyebrow" styleClass="pf-eyebrow"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="%common.home" onAction="#showHome" fx:id="navHome" styleClass="student-nav-btn"/>
            <Button text="%student.nav.skills" onAction="#showSkills" fx:id="navSkills" styleClass="student-nav-btn"/>

            <Region prefWidth="14"/>
            <Region styleClass="nav-vrule" prefWidth="1" maxWidth="1" prefHeight="22" maxHeight="22"/>
            <Region prefWidth="14"/>

            <Button fx:id="pomodoroBtn" onAction="#togglePomodoro" styleClass="pomodoro-toggle"/>
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle"/>
            <MenuButton fx:id="userMenu" styleClass="header-username">
                <items>
                    <MenuItem fx:id="menuProfile" text="%common.profile" onAction="#showProfile"/>
                    <MenuItem fx:id="menuSettings" text="%common.settings" onAction="#showSettings"/>
                </items>
            </MenuButton>
            <Button text="%common.signout" onAction="#handleLogout" styleClass="nav-signout"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>
</BorderPane>
