<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.sections.SectionEditController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Back"/>
            <VBox spacing="4.0">
                <Label styleClass="page-title" text="Edit Section"/>
                <Label styleClass="page-subtitle" text="Update section title and ordering before managing lessons."/>
            </VBox>
        </HBox>
    </top>
    <center>
        <HBox spacing="22.0">
            <VBox spacing="16.0" styleClass="form-card" HBox.hgrow="ALWAYS">
                <VBox spacing="8.0">
                    <Label styleClass="field-label" text="Title"/>
                    <TextField fx:id="titleField" promptText="Section title"/>
                    <Label fx:id="titleErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                </VBox>
                <VBox spacing="8.0">
                    <Label styleClass="field-label" text="Position"/>
                    <TextField fx:id="positionField" promptText="Section order"/>
                    <Label fx:id="positionErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                </VBox>
            </VBox>
            <VBox spacing="16.0" prefWidth="260.0">
                <VBox spacing="10.0" styleClass="detail-card">
                    <Label styleClass="section-title" text="Editing"/>
                    <Label styleClass="detail-body" text="Use this dedicated screen to update section ordering without touching lessons." wrapText="true"/>
                </VBox>
                <StackPane VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Cancel"/>
                    <Button mnemonicParsing="false" onAction="#handleSave" styleClass="primary-button" text="Save"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
