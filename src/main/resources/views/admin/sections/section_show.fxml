<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.sections.SectionShowController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back"/>
            <VBox spacing="4.0">
                <Label fx:id="headerTitleLabel" styleClass="page-title" text="Section"/>
                <Label styleClass="page-subtitle" text="Review the section and open its lessons from here."/>
            </VBox>
            <StackPane HBox.hgrow="ALWAYS"/>
            <Button fx:id="openLessonButton" mnemonicParsing="false" onAction="#handleOpenLesson" styleClass="secondary-button" text="Open Lesson"/>
            <Button fx:id="addLessonButton" mnemonicParsing="false" onAction="#handleAddLesson" styleClass="hero-button" text="Add Lesson"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="22.0">
            <BorderPane.margin>
                <Insets top="24.0"/>
            </BorderPane.margin>
            <HBox spacing="22.0">
                <VBox spacing="18.0" styleClass="admin-overview-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                        <VBox alignment="CENTER" styleClass="admin-avatar-tile admin-avatar-emerald">
                            <Label fx:id="sectionInitialLabel" styleClass="admin-avatar-letter" text="S"/>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="detail-label" text="SECTION WORKSPACE"/>
                            <Label fx:id="titleValueLabel" styleClass="admin-view-title" text="-"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="12.0" styleClass="admin-metric-strip">
                        <VBox spacing="5.0" styleClass="admin-mini-stat" HBox.hgrow="ALWAYS">
                            <Label styleClass="meta-label" text="Position"/>
                            <Label fx:id="positionValueLabel" styleClass="meta-value" text="-"/>
                        </VBox>
                        <VBox spacing="5.0" styleClass="admin-mini-stat" HBox.hgrow="ALWAYS">
                            <Label styleClass="meta-label" text="Lessons"/>
                            <Label fx:id="lessonCountLabel" styleClass="meta-value" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox spacing="14.0" styleClass="admin-side-card" prefWidth="330.0">
                    <Label styleClass="section-title" text="Metadata"/>
                    <VBox spacing="6.0">
                        <Label styleClass="meta-label" text="Created"/>
                        <Label fx:id="createdAtValueLabel" styleClass="meta-value" text="-"/>
                    </VBox>
                    <VBox spacing="6.0" styleClass="admin-description-box">
                        <Label styleClass="meta-label" text="Next step"/>
                        <Label styleClass="detail-body" text="Open a lesson from the table or add a new one to expand this section." wrapText="true"/>
                    </VBox>
                </VBox>
            </HBox>
            <VBox spacing="10.0" styleClass="courses-card admin-table-card" VBox.vgrow="ALWAYS">
                <VBox spacing="6.0" styleClass="courses-card-header">
                    <Label styleClass="card-title" text="Lessons"/>
                    <Label styleClass="card-subtitle" text="Open a lesson to preview it, or add a new one to this section."/>
                </VBox>
                <TableView fx:id="lessonTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="lessonTitleColumn" minWidth="420.0" prefWidth="520.0" text="TITLE"/>
                        <TableColumn fx:id="lessonTypeColumn" minWidth="180.0" prefWidth="220.0" text="TYPE"/>
                        <TableColumn fx:id="lessonPositionColumn" minWidth="150.0" prefWidth="170.0" text="POSITION"/>
                        <TableColumn fx:id="lessonActionsColumn" minWidth="330.0" prefWidth="340.0" text="ACTIONS"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
