<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.sections.SectionShowController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back"/>
            <VBox spacing="4.0">
                <Label fx:id="headerTitleLabel" styleClass="page-title" text="Section"/>
                <Label styleClass="page-subtitle" text="Review the section and open its lessons from here."/>
            </VBox>
            <StackPane HBox.hgrow="ALWAYS"/>
            <Button fx:id="openLessonButton" mnemonicParsing="false" onAction="#handleOpenLesson" styleClass="secondary-button" text="Open Lesson"/>
            <Button mnemonicParsing="false" onAction="#handleAddLesson" styleClass="hero-button" text="+ Add Lesson"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="22.0">
            <HBox spacing="22.0">
                <VBox spacing="12.0" styleClass="detail-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="section-title" text="Section Details"/>
                    <Label styleClass="detail-label" text="Title"/>
                    <Label fx:id="titleValueLabel" styleClass="detail-value-title" text="-"/>
                    <Label styleClass="detail-label" text="Position"/>
                    <Label fx:id="positionValueLabel" styleClass="detail-value" text="-"/>
                </VBox>
                <VBox spacing="12.0" styleClass="detail-card" prefWidth="280.0">
                    <Label styleClass="section-title" text="Metadata"/>
                    <Label styleClass="detail-label" text="Created"/>
                    <Label fx:id="createdAtValueLabel" styleClass="detail-value" text="-"/>
                </VBox>
            </HBox>
            <VBox spacing="10.0" styleClass="courses-card" VBox.vgrow="ALWAYS">
                <VBox spacing="6.0" styleClass="courses-card-header">
                    <Label styleClass="card-title" text="Lessons"/>
                    <Label styleClass="card-subtitle" text="Open a lesson to preview it, or add a new one to this section."/>
                </VBox>
                <TableView fx:id="lessonTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="lessonTitleColumn" prefWidth="460.0" text="TITLE"/>
                        <TableColumn fx:id="lessonTypeColumn" prefWidth="180.0" text="TYPE"/>
                        <TableColumn fx:id="lessonPositionColumn" prefWidth="180.0" text="POSITION"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
