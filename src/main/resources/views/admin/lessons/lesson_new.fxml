<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.lessons.LessonNewController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Back"/>
            <VBox spacing="4.0">
                <Label styleClass="page-title" text="Create Lesson"/>
                <Label styleClass="page-subtitle" text="Choose a type and the form will adapt for text, PDF, or video lessons."/>
            </VBox>
        </HBox>
    </top>
    <center>
        <HBox spacing="22.0">
            <VBox spacing="16.0" styleClass="form-card" HBox.hgrow="ALWAYS">
                <VBox spacing="8.0">
                    <Label styleClass="field-label" text="Title"/>
                    <TextField fx:id="titleField" promptText="Lesson title"/>
                    <Label fx:id="titleErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                </VBox>
                <HBox spacing="16.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="Type"/>
                        <ComboBox fx:id="typeComboBox"/>
                        <Label fx:id="typeErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="Position"/>
                        <TextField fx:id="positionField" promptText="Lesson order"/>
                        <Label fx:id="positionErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                    </VBox>
                </HBox>
                <VBox fx:id="contentBox" spacing="8.0">
                    <Label styleClass="field-label" text="Content"/>
                    <TextArea fx:id="contentArea" prefHeight="260.0" promptText="Lesson content for TEXT lessons" wrapText="true"/>
                    <Label fx:id="contentErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                </VBox>
                <VBox fx:id="fileBox" spacing="10.0" managed="false" visible="false">
                    <Label styleClass="field-label" text="File"/>
                    <HBox spacing="12.0">
                        <Button mnemonicParsing="false" onAction="#handleChooseFile" styleClass="secondary-button" text="Choose File"/>
                        <Label fx:id="selectedFileLabel" styleClass="detail-body" text="No file selected"/>
                    </HBox>
                    <Label fx:id="fileErrorLabel" managed="false" styleClass="form-error" text="" visible="false"/>
                </VBox>
            </VBox>
            <VBox spacing="16.0" prefWidth="280.0">
                <VBox spacing="10.0" styleClass="detail-card">
                    <Label styleClass="section-title" text="Type Rules"/>
                    <Label styleClass="detail-body" text="TEXT lessons store written content. PDF and VIDEO lessons store a local uploaded file path instead." wrapText="true"/>
                </VBox>
                <StackPane VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="secondary-button" text="Cancel"/>
                    <Button mnemonicParsing="false" onAction="#handleSave" styleClass="primary-button" text="Save"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
