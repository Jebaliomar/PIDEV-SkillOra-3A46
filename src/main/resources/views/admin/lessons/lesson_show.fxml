<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.lessons.LessonShowController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back"/>
            <VBox spacing="4.0">
                <Label fx:id="headerTitleLabel" styleClass="page-title" text="Lesson"/>
                <Label styleClass="page-subtitle" text="Preview lesson content in a dedicated read-only screen."/>
            </VBox>
            <StackPane HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#handleEdit" styleClass="secondary-button" text="Edit"/>
            <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="danger-button" text="Delete"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fillWidth="true" spacing="22.0">
                    <HBox spacing="22.0">
                        <VBox spacing="12.0" styleClass="detail-card" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-title" text="Lesson"/>
                            <Label styleClass="detail-label" text="Title"/>
                            <Label fx:id="titleValueLabel" styleClass="detail-value-title" text="-"/>
                        </VBox>
                        <VBox prefWidth="260.0" spacing="12.0" styleClass="detail-card">
                            <Label styleClass="section-title" text="Metadata"/>
                            <Label styleClass="detail-label" text="Type"/>
                            <Label fx:id="typeValueLabel" styleClass="status-pill" text="-"/>
                            <Label styleClass="detail-label" text="Position"/>
                            <Label fx:id="positionValueLabel" styleClass="detail-value" text="-"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="14.0" styleClass="detail-card">
                        <Label styleClass="section-title" text="Lesson Preview"/>
                        <StackPane fx:id="contentContainer"
                                   minHeight="360.0"
                                   prefHeight="420.0"
                                   maxHeight="420.0"
                                   maxWidth="1.7976931348623157E308"
                                   style="-fx-background-color: rgba(248,250,252,0.92); -fx-background-radius: 18; -fx-border-color: rgba(226,232,240,0.9); -fx-border-radius: 18; -fx-padding: 12;">
                            <VBox alignment="CENTER" spacing="8.0">
                                <Label styleClass="detail-value" text="No preview available"/>
                                <Label styleClass="detail-body" text="Select a lesson to display its content." wrapText="true"/>
                            </VBox>
                        </StackPane>
                        <Label fx:id="previewStatusLabel" managed="false" text="" visible="false" wrapText="true"/>
                        <HBox fx:id="previewActionsBox" alignment="CENTER_LEFT" managed="false" spacing="12.0" visible="false"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
