<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.courses.CourseShowController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Course Details"/>
            <Button mnemonicParsing="false" onAction="#handleBack" text="Back to List"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <GridPane hgap="16.0" vgap="12.0">
                <Label style="-fx-font-weight: bold;" text="Title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="titleValueLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label style="-fx-font-weight: bold;" text="Category" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="categoryValueLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label style="-fx-font-weight: bold;" text="Status" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="statusValueLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label style="-fx-font-weight: bold;" text="Created At" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="createdAtValueLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>

            <Separator/>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Course Sections"/>
                <TableView fx:id="sectionTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="sectionTitleColumn" prefWidth="420.0" text="Title"/>
                        <TableColumn fx:id="positionColumn" prefWidth="140.0" text="Position"/>
                        <TableColumn fx:id="sectionCreatedAtColumn" prefWidth="220.0" text="Created At"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
