<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.courses.CourseNewController">
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Add Course"/>
            <Label text="Create a new course using the existing backend service."/>
        </VBox>
    </top>
    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <GridPane hgap="12.0" vgap="12.0">
                <Label text="Title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="titleField" promptText="Course title" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Category" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="categoryField" promptText="Course category" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="statusField" promptText="Published / Draft" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Thumbnail" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="thumbnailField" promptText="Thumbnail path or URL" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Description" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextArea fx:id="descriptionArea" prefHeight="180.0" promptText="Course description"
                          wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <Button mnemonicParsing="false" onAction="#handleCancel" text="Cancel"/>
            <Button mnemonicParsing="false" onAction="#handleSave" text="Save"/>
        </HBox>
    </bottom>
</BorderPane>
