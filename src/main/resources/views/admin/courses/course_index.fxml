<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.courses.CourseIndexController">
    <top>
        <VBox spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <HBox spacing="12.0">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Courses"/>
                <Button mnemonicParsing="false" onAction="#handleAddCourse" text="Add Course"/>
            </HBox>
            <HBox spacing="12.0">
                <TextField fx:id="searchField" promptText="Search by title..." HBox.hgrow="ALWAYS"/>
                <Button fx:id="viewButton" mnemonicParsing="false" onAction="#handleViewCourse" text="View"/>
                <Button fx:id="editButton" mnemonicParsing="false" onAction="#handleEditCourse" text="Edit"/>
                <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDeleteCourse" text="Delete"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <TableView fx:id="courseTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titleColumn" prefWidth="280.0" text="Title"/>
                    <TableColumn fx:id="categoryColumn" prefWidth="220.0" text="Category"/>
                    <TableColumn fx:id="statusColumn" prefWidth="170.0" text="Status"/>
                    <TableColumn fx:id="createdAtColumn" prefWidth="220.0" text="Created At"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
