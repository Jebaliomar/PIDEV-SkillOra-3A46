<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1120.0" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.courses.CourseIndexController">
    <top>
        <VBox spacing="28.0">
            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="7.0">
                    <Label styleClass="page-title" text="Courses"/>
                    <Label styleClass="page-subtitle" text="Create and manage courses (basic info only for now)."/>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#handleAddCourse" styleClass="hero-button" text="+ Add course"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="0.0" styleClass="courses-card">
            <VBox spacing="6.0" styleClass="courses-card-header">
                <padding>
                    <Insets top="28.0" right="34.0" bottom="22.0" left="34.0"/>
                </padding>
                <Label styleClass="card-title" text="All Courses"/>
                <Label styleClass="card-subtitle" text="Click a course to manage its details."/>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <TextField fx:id="searchField" promptText="Search by title, category, or status" styleClass="search-field list-search-field" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="resultsLabel" styleClass="results-label" text="0 courses"/>
                </HBox>
            </VBox>
            <TableView fx:id="courseTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titleColumn" prefWidth="410.0" text="COURSE"/>
                    <TableColumn fx:id="categoryColumn" prefWidth="280.0" text="CATEGORY"/>
                    <TableColumn fx:id="statusColumn" prefWidth="170.0" text="STATUS"/>
                    <TableColumn fx:id="createdAtColumn" prefWidth="180.0" text="CREATED"/>
                    <TableColumn fx:id="actionsColumn" prefWidth="250.0" text="ACTIONS"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
