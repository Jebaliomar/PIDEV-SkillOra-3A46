<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-scroll-pane"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.front.courses.FrontCourseShowController">
    <content>
        <VBox spacing="24.0" styleClass="module-page">
            <HBox spacing="28.0" styleClass="front-course-hero">
                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="categoryLabel" styleClass="front-course-hero-category" text="Category"/>
                    <Label fx:id="courseTitleLabel" styleClass="front-course-hero-title" text="Course Title" wrapText="true"/>
                    <Label fx:id="descriptionLabel" styleClass="front-course-hero-description" text="Course description" wrapText="true"/>
                    <VBox spacing="9.0" styleClass="front-course-progress-panel">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label fx:id="progressLabel" styleClass="front-course-progress-value" text="0% complete"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="completedLessonsLabel" styleClass="front-course-progress-meta" text="0 / 0 lessons"/>
                        </HBox>
                        <ProgressBar fx:id="courseProgressBar" maxWidth="Infinity" progress="0.0"/>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Button fx:id="continueButton" mnemonicParsing="false" onAction="#handleContinueCourse" styleClass="hero-button" text="Start Course"/>
                        <Button fx:id="certificateButton" managed="false" mnemonicParsing="false" onAction="#handleOpenCertificate" styleClass="secondary-button front-certificate-button" text="Open Certificate" visible="false"/>
                    </HBox>
                </VBox>
                <StackPane prefWidth="280.0" minWidth="280.0" maxWidth="280.0" styleClass="front-course-hero-thumb-shell">
                    <ImageView fx:id="thumbnailImageView" fitHeight="180.0" fitWidth="280.0" preserveRatio="false"/>
                    <Label fx:id="thumbnailFallbackLabel" styleClass="front-course-thumb-fallback" text="No Thumbnail"/>
                </StackPane>
            </HBox>

            <VBox spacing="18.0" styleClass="front-section-card">
                <VBox spacing="4.0">
                    <Label styleClass="section-title" text="Course Content"/>
                    <Label styleClass="front-section-subtitle" text="Explore sections and open any lesson to start learning."/>
                </VBox>
                <VBox fx:id="sectionsAccordion" spacing="12.0" styleClass="front-sections-list"/>
            </VBox>

            <VBox spacing="20.0" styleClass="course-insights-shell">
                <HBox alignment="CENTER_LEFT" spacing="18.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="course-insights-kicker" text="HELPFUL SIGNALS"/>
                        <Label styleClass="course-insights-title" text="Why choose this course?"/>
                        <Label styleClass="course-insights-subtitle" text="Clear and simple indicators showing how practical and supported this topic is." wrapText="true"/>
                    </VBox>
                    <Button fx:id="loadInsightsButton" focusTraversable="false" mnemonicParsing="false" onAction="#handleLoadInsights" styleClass="course-insights-button" text="Show Insights"/>
                </HBox>

                <VBox fx:id="insightsLoadingBox" managed="false" spacing="12.0" styleClass="course-insights-loading" visible="false">
                    <HBox spacing="12.0">
                        <Region styleClass="insight-skeleton-line" HBox.hgrow="ALWAYS"/>
                        <Region prefWidth="160.0" styleClass="insight-skeleton-line"/>
                    </HBox>
                    <HBox spacing="12.0">
                        <Region styleClass="insight-skeleton-card" HBox.hgrow="ALWAYS"/>
                        <Region styleClass="insight-skeleton-card" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Label fx:id="insightsErrorLabel" managed="false" styleClass="course-insights-error" visible="false" wrapText="true"/>

                <VBox fx:id="insightsResultBox" managed="false" spacing="18.0" visible="false">
                    <VBox spacing="4.0" styleClass="course-insights-keyword-card">
                        <Label styleClass="course-insights-card-kicker" text="MAIN TOPIC DETECTED"/>
                        <Label fx:id="insightsKeywordLabel" styleClass="course-insights-keyword" text="N/A"/>
                    </VBox>
                    <VBox fx:id="insightsCardsBox" spacing="14.0"/>
                    <VBox spacing="14.0" styleClass="course-insights-chart-card">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label styleClass="course-insights-chart-title" text="Topic Strength Snapshot"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label styleClass="course-insights-chart-meta" text="easy 0-100 scale"/>
                        </HBox>
                        <VBox fx:id="insightsChartBox" spacing="10.0"/>
                    </VBox>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
