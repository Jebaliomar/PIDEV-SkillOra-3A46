<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-scroll-pane"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.front.courses.FrontCourseShowController">
    <content>
        <VBox spacing="24.0" styleClass="module-page">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button mnemonicParsing="false" onAction="#handleBackToBrowse" styleClass="secondary-button" text="Back to Catalog"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="28.0" styleClass="front-course-hero">
                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="categoryLabel" styleClass="front-course-hero-category" text="Category"/>
                    <Label fx:id="courseTitleLabel" styleClass="front-course-hero-title" text="Course Title" wrapText="true"/>
                    <Label fx:id="descriptionLabel" styleClass="front-course-hero-description" text="Course description" wrapText="true"/>
                    <HBox spacing="10.0">
                        <Label fx:id="sectionsCountLabel" styleClass="front-course-stat-pill" text="0 sections"/>
                        <Label fx:id="lessonsCountLabel" styleClass="front-course-stat-pill" text="0 lessons"/>
                    </HBox>
                    <HBox spacing="12.0">
                        <Button fx:id="startCourseButton" disable="true" mnemonicParsing="false" onAction="#handleStartCourse" styleClass="hero-button" text="Start Learning"/>
                        <Button mnemonicParsing="false" onAction="#handleBackToBrowse" styleClass="secondary-button" text="Browse More"/>
                    </HBox>
                </VBox>
                <StackPane prefWidth="280.0" minWidth="280.0" maxWidth="280.0" styleClass="front-course-hero-thumb-shell">
                    <ImageView fx:id="thumbnailImageView" fitHeight="180.0" fitWidth="280.0" preserveRatio="false"/>
                    <Label fx:id="thumbnailFallbackLabel" styleClass="front-course-thumb-fallback" text="No Thumbnail"/>
                </StackPane>
            </HBox>

            <VBox spacing="18.0" styleClass="front-section-card">
                <VBox spacing="4.0">
                    <Label styleClass="section-title" text="Course Content"/>
                    <Label styleClass="front-section-subtitle" text="Explore sections and open any lesson to start learning."/>
                </VBox>
                <Accordion fx:id="sectionsAccordion"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
