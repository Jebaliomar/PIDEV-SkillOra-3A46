<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.front.courses.FrontCourseConsumeController">
    <top>
        <VBox maxWidth="1320.0" spacing="10.0" styleClass="front-page-header front-page-header-compact">
            <HBox alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="breadcrumb-button" text="Courses  >  Course Details  >  Lesson"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lessonTypeLabel" styleClass="status-pill front-consume-status" text="TEXT"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="18.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="courseTitleLabel" styleClass="section-title front-consume-course-name" text="Course"/>
                    <Label fx:id="lessonTitleLabel" styleClass="front-consume-title front-page-title-compact" text="Lesson" wrapText="true"/>
                </VBox>
                <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button front-inline-back" text="Back to Course"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox maxWidth="1320.0" spacing="20.0">
            <VBox prefWidth="304.0" spacing="14.0" styleClass="front-consume-sidebar front-consume-curriculum">
                <VBox spacing="6.0">
                    <Label styleClass="section-title" text="Course Lessons"/>
                    <Label styleClass="front-section-subtitle" text="Move through the curriculum without compressing the lesson preview." wrapText="true"/>
                </VBox>
                <VBox spacing="9.0" styleClass="front-consume-progress-panel">
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label fx:id="progressLabel" styleClass="front-course-progress-value" text="0% complete"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="completedLessonsLabel" styleClass="front-course-progress-meta" text="0 / 0"/>
                    </HBox>
                    <ProgressBar fx:id="courseProgressBar" maxWidth="Infinity" progress="0.0"/>
                    <Button fx:id="certificateButton" managed="false" mnemonicParsing="false" onAction="#handleOpenCertificate" maxWidth="Infinity" styleClass="secondary-button front-certificate-button" text="Open Certificate" visible="false"/>
                </VBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="sectionsAccordion" spacing="10.0" styleClass="front-sections-list"/>
                    </content>
                </ScrollPane>
            </VBox>
            <VBox spacing="16.0" HBox.hgrow="ALWAYS" styleClass="front-consume-main">
                <StackPane fx:id="contentContainer" minHeight="420.0" prefHeight="560.0" VBox.vgrow="ALWAYS" styleClass="front-consume-preview"/>
                <Label fx:id="previewStatusLabel" managed="false" styleClass="detail-body front-consume-meta" text="" visible="false" wrapText="true"/>
                <HBox fx:id="previewActionsBox" alignment="CENTER_LEFT" managed="false" spacing="12.0" visible="false"/>
                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="front-consume-nav">
                    <Button fx:id="previousButton" mnemonicParsing="false" onAction="#handlePrevious" styleClass="secondary-button" text="Previous"/>
                    <Button fx:id="nextButton" mnemonicParsing="false" onAction="#handleNext" styleClass="primary-button" text="Next"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
