<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-scroll-pane"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.front.home.FrontHomeController">
    <content>
        <VBox fillWidth="true" maxWidth="1160.0" spacing="30.0" styleClass="module-page">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="6.0">
                    <Label styleClass="page-title" text="Home"/>
                    <Label styleClass="page-subtitle" text="Discover the newest additions to your learning workspace."/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#handleOpenForum" styleClass="secondary-button" text="Forum"/>
            </HBox>

            <VBox spacing="22.0" styleClass="front-section-card">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <VBox spacing="4.0">
                        <Label styleClass="section-title" text="Latest Courses"/>
                        <Label styleClass="front-section-subtitle" text="The three most recent courses added to SkillORA."/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button mnemonicParsing="false" onAction="#handleViewAll" styleClass="primary-button" text="View All"/>
                </HBox>
                <FlowPane fx:id="latestCoursesPane" prefWrapLength="1040.0"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
