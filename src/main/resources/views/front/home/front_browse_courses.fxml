<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="module-page"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.front.home.FrontBrowseCoursesController">
    <top>
        <VBox maxWidth="1240.0" spacing="20.0">
            <VBox spacing="6.0">
                <Label styleClass="page-title" text="Browse Courses"/>
                <Label styleClass="page-subtitle" text="Search, filter, and sort the full course catalog."/>
            </VBox>
            <HBox spacing="16.0" styleClass="front-toolbar-card">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Search"/>
                    <TextField fx:id="searchField" promptText="Search by course title" styleClass="list-search-field"/>
                </VBox>
                <VBox spacing="6.0" prefWidth="220.0">
                    <Label styleClass="field-label" text="Sort"/>
                    <ComboBox fx:id="sortComboBox"/>
                </VBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox maxWidth="1240.0" spacing="24.0">
            <VBox prefWidth="250.0" spacing="14.0" styleClass="front-filter-card">
                <Label styleClass="section-title" text="Categories"/>
                <Label styleClass="front-section-subtitle" text="Refine the course list by topic." wrapText="true"/>
                <VBox fx:id="categoryFilterBox" spacing="10.0"/>
            </VBox>
            <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="resultsLabel" styleClass="results-label" text="0 courses"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="coursesGrid" prefWrapLength="930.0"/>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
