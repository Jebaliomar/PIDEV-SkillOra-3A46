<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.UserAssessmentController">
    <stylesheets>
        <URL value="@styles/style.css"/>
        <URL value="@user-assessment.css"/>
    </stylesheets>

    <top>
        <fx:include fx:id="navbar" source="views/front/common/SkilloraNavbar.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="12" styleClass="page-container">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>

                    <VBox spacing="12" styleClass="hero-section">
                        <children>
                            <Label text="LEARNING SPACE" styleClass="hero-badge"/>
                            <Label text="My Assessments" styleClass="hero-title"/>
                            <Label text="Track your progress, launch pending assessments, and review completed results."
                                   wrapText="true"
                                   styleClass="hero-subtitle"/>

                            <HBox spacing="10">
                                <children>
                                    <Button text="View assessments" styleClass="hero-button"/>
                                    <Button text="Hangman Assessment"
                                            styleClass="hero-button"
                                            onAction="#openHangmanAssessments"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="10" styleClass="filter-section">
                        <children>
                            <Label text="Assessment List" styleClass="section-title"/>
                            <Label text="Use filters to focus on pending or completed work."
                                   styleClass="section-subtitle"/>

                            <HBox spacing="10">
                                <children>
                                    <Button fx:id="btnAll"
                                            text="All"
                                            onAction="#handleAllFilter"
                                            styleClass="filter-button"/>

                                    <Button fx:id="btnTodo"
                                            text="To do"
                                            onAction="#handleTodoFilter"
                                            styleClass="filter-button"/>

                                    <Button fx:id="btnCompleted"
                                            text="Completed"
                                            onAction="#handleCompletedFilter"
                                            styleClass="filter-button"/>

                                    <Button fx:id="btnExam"
                                            text="Exam"
                                            onAction="#handleExamFilter"
                                            styleClass="filter-button"/>

                                    <Button fx:id="btnQuiz"
                                            text="Quiz"
                                            onAction="#handleQuizFilter"
                                            styleClass="filter-button"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox fx:id="evaluationContainer" spacing="12"/>

                    <HBox spacing="10" alignment="CENTER" styleClass="pagination-box">
                        <children>
                            <Button fx:id="prevPageButton"
                                    text="Previous"
                                    onAction="#handlePreviousPage"
                                    styleClass="pagination-button"/>

                            <Label fx:id="pageLabel"
                                   text="Page 1 / 1"
                                   styleClass="pagination-label"/>

                            <Button fx:id="nextPageButton"
                                    text="Next"
                                    onAction="#handleNextPage"
                                    styleClass="pagination-button"/>
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
