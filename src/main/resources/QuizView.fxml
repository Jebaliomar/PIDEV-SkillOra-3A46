<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1400.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.QuizController"
            styleClass="root">

    <left>
        <fx:include fx:id="adminSidebar" source="viewsadmin/common/AdminSidebar.fxml"/>
    </left>

    <center>
        <VBox spacing="22.0" styleClass="main-content">
            <padding>
                <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="titleLabel"
                           text="Quiz"
                           styleClass="label-title"
                           wrapText="true"/>

                    <Label fx:id="subtitleLabel"
                           text="Gestion des questions et options"
                           styleClass="label-subtitle"
                           wrapText="true"/>
                </VBox>

                <Button text="Retour"
                        minWidth="110.0"
                        prefWidth="150.0"
                        prefHeight="40.0"
                        onAction="#retour"
                        styleClass="button-secondary"/>

                <Button text="+ Ajouter Question"
                        minWidth="170.0"
                        prefWidth="190.0"
                        prefHeight="40.0"
                        onAction="#ouvrirAjoutQuestion"
                        styleClass="button-primary"/>
            </HBox>

            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        VBox.vgrow="ALWAYS"
                        styleClass="card-centered">
                <content>
                    <VBox fx:id="questionContainer"
                          spacing="20.0"
                          fillWidth="true"
                          styleClass="question-container"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
