<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1400.0" prefHeight="820.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.EvaluationController">

    <children>

        <VBox prefWidth="1400.0"
              prefHeight="820.0"
              spacing="28.0"
              alignment="TOP_LEFT">

            <padding>
                <Insets top="18.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>

            <!-- Grand titre -->
            <Label text="Create Evaluation" styleClass="page-big-title"/>

            <!-- Card principale -->
            <AnchorPane prefWidth="1320.0"
                        prefHeight="680.0"
                        styleClass="create-card">

                <children>

                    <!-- Champ ID caché -->
                    <TextField fx:id="idField" visible="false" managed="false"/>

                    <VBox layoutX="28.0"
                          layoutY="26.0"
                          prefWidth="1260.0"
                          spacing="22.0">

                        <children>

                            <!-- Title -->
                            <VBox spacing="8.0">
                                <children>
                                    <Label text="Title" styleClass="form-label"/>
                                    <TextField fx:id="titleField"
                                               prefWidth="1240.0"
                                               prefHeight="46.0"
                                               promptText=""
                                               styleClass="form-input"/>
                                    <Label fx:id="titleErrorLabel" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <!-- Description -->
                            <VBox spacing="8.0">
                                <children>
                                    <Label text="Description" styleClass="form-label"/>
                                    <TextArea fx:id="descriptionField"
                                              prefWidth="1240.0"
                                              prefHeight="95.0"
                                              wrapText="true"
                                              styleClass="form-textarea"/>
                                    <Label fx:id="descriptionErrorLabel" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <!-- Type + Duration -->
                            <HBox spacing="24.0">
                                <children>

                                    <VBox spacing="8.0" prefWidth="608.0">
                                        <children>
                                            <Label text="Type" styleClass="form-label"/>
                                            <ComboBox fx:id="typeComboBox"
                                                      prefWidth="608.0"
                                                      prefHeight="46.0"
                                                      promptText="Choose a type"
                                                      styleClass="form-combo"/>
                                            <Label fx:id="typeErrorLabel" styleClass="error-label"/>

                                            <Button fx:id="btnUploadDocx"
                                                    text="Upload DOCX"
                                                    prefWidth="180.0"
                                                    prefHeight="38.0"
                                                    visible="false"
                                                    managed="false"
                                                    onAction="#uploadDocx"
                                                    styleClass="button-secondary"/>

                                            <Label fx:id="docxLabel"
                                                   visible="false"
                                                   managed="false"
                                                   styleClass="upload-label"/>
                                        </children>
                                    </VBox>

                                    <VBox spacing="8.0" prefWidth="608.0">
                                        <children>
                                            <Label text="Duration (minutes)" styleClass="form-label"/>
                                            <TextField fx:id="durationField"
                                                       prefWidth="608.0"
                                                       prefHeight="46.0"
                                                       styleClass="form-input"/>
                                            <Label fx:id="durationErrorLabel" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>

                            <!-- Score -->
                            <VBox spacing="8.0" prefWidth="608.0">
                                <children>
                                    <Label text="Total Score (max score)" styleClass="form-label"/>
                                    <TextField fx:id="scoreField"
                                               prefWidth="608.0"
                                               prefHeight="46.0"
                                               text="0"
                                               styleClass="form-input"/>
                                    <Label fx:id="scoreErrorLabel" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <!-- Boutons -->
                            <HBox spacing="14.0">
                                <children>
                                    <Button fx:id="btnAjouter"
                                            text="Save"
                                            prefWidth="118.0"
                                            prefHeight="46.0"
                                            onAction="#ajouterEvaluation"
                                            styleClass="button-save"/>

                                    <Button fx:id="btnModifier"
                                            text="Update"
                                            prefWidth="118.0"
                                            prefHeight="46.0"
                                            onAction="#modifierEvaluation"
                                            styleClass="button-save"
                                            visible="false"
                                            managed="false"/>

                                    <Button text="Cancel"
                                            prefWidth="118.0"
                                            prefHeight="46.0"
                                            onAction="#viderChamps"
                                            styleClass="button-cancel"/>

                                    <Button text="Afficher Liste"
                                            prefWidth="150.0"
                                            prefHeight="46.0"
                                            onAction="#afficherListe"
                                            styleClass="button-secondary"/>
                                </children>
                            </HBox>

                        </children>
                    </VBox>

                </children>
            </AnchorPane>

        </VBox>

    </children>
</AnchorPane>