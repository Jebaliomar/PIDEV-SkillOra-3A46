<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.EvaluationController">

    <children>
        <Label layoutX="40.0" layoutY="40.0" text="Title" />
        <Label layoutX="40.0" layoutY="80.0" text="Description" />
        <Label layoutX="40.0" layoutY="120.0" text="Type" />
        <Label layoutX="40.0" layoutY="160.0" text="Duration" />
        <Label layoutX="40.0" layoutY="200.0" text="Total Score" />

        <TextField fx:id="titleField" layoutX="150.0" layoutY="36.0" />
        <TextField fx:id="descriptionField" layoutX="150.0" layoutY="76.0" />
        <TextField fx:id="typeField" layoutX="150.0" layoutY="116.0" />
        <TextField fx:id="durationField" layoutX="150.0" layoutY="156.0" />
        <TextField fx:id="scoreField" layoutX="150.0" layoutY="196.0" />

        <Button layoutX="220.0"
                layoutY="260.0"
                text="Ajouter Evaluation"
                onAction="#ajouterEvaluation" />
    </children>
</AnchorPane>