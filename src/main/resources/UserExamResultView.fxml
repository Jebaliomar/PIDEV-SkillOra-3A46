<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="1280.0" prefHeight="900.0"
            stylesheets="@user-pass-assessment.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.UserExamResultController">

    <children>
        <ScrollPane fitToWidth="true"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="16.0"
                      styleClass="pass-page"
                      prefWidth="1240.0">

                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                    </padding>

                    <children>

                        <!-- HEADER -->
                        <VBox spacing="8.0" styleClass="pass-header">
                            <children>
                                <Label fx:id="titleLabel" text="Exam Result" styleClass="pass-title"/>
                                <Label fx:id="subtitleLabel"
                                       text="Voici votre examen et votre réponse soumise"
                                       styleClass="pass-subtitle"/>
                                <Label fx:id="scoreLabel" text="Score : -" styleClass="result-stat"/>
                                <Label fx:id="aiUsageLabel" text="Usage IA : -" styleClass="result-stat"/>
                                <Label fx:id="plagiarismLabel" text="Plagiat : -" styleClass="result-stat"/>
                                <Label fx:id="fraudLabel" text="Fraude : -" styleClass="result-stat"/>
                            </children>
                        </VBox>

                        <!-- DOCUMENT -->
                        <Label text="Document de l'examen" styleClass="section-label"/>

                        <VBox spacing="10.0" styleClass="document-card">
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                            </padding>

                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="pdf-toolbar">
                                    <children>
                                        <Button text="◀"
                                                onAction="#handlePreviousPdfPage"
                                                styleClass="secondary-button"/>

                                        <Label fx:id="pdfPageLabel"
                                               text="Page 0 / 0"
                                               styleClass="pdf-page-indicator"/>

                                        <Button text="▶"
                                                onAction="#handleNextPdfPage"
                                                styleClass="secondary-button"/>

                                        <Region HBox.hgrow="ALWAYS"/>

                                        <Button fx:id="openPdfButton"
                                                text="Open PDF"
                                                onAction="#handleOpenPdfExternally"
                                                styleClass="secondary-button"/>
                                    </children>
                                </HBox>

                                <StackPane styleClass="pdf-surface">
                                    <children>
                                        <ScrollPane fx:id="pdfScrollPane"
                                                    fitToWidth="true"
                                                    fitToHeight="true"
                                                    pannable="true"
                                                    visible="false"
                                                    managed="false"
                                                    prefHeight="520.0"
                                                    styleClass="pdf-scroll">
                                            <content>
                                                <StackPane>
                                                    <padding>
                                                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
                                                    </padding>
                                                    <children>
                                                        <ImageView fx:id="pdfImageView"
                                                                   preserveRatio="true"
                                                                   smooth="true"
                                                                   fitWidth="980.0"/>
                                                    </children>
                                                </StackPane>
                                            </content>
                                        </ScrollPane>

                                        <TextArea fx:id="examContentArea"
                                                  editable="false"
                                                  wrapText="true"
                                                  visible="false"
                                                  managed="false"
                                                  prefHeight="520.0"
                                                  styleClass="exam-doc-area"/>
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>

                        <!-- REPONSE -->
                        <Label text="Votre réponse / Remise" styleClass="section-label"/>

                        <VBox spacing="10.0" styleClass="submission-card">
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                            </padding>

                            <children>
                                <VBox spacing="6.0" styleClass="submission-toolbar">
                                    <padding>
                                        <Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/>
                                    </padding>
                                    <children>
                                        <Label text="Votre réponse" styleClass="section-label"/>
                                    </children>
                                </VBox>

                                <TextArea fx:id="answerArea"
                                          styleClass="answer-area"
                                          editable="false"
                                          wrapText="true"
                                          prefHeight="220.0"/>
                            </children>
                        </VBox>

                        <!-- UPLOAD -->
                        <VBox spacing="8.0" styleClass="upload-card">
                            <padding>
                                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
                            </padding>

                            <children>
                                <Label text="Déposer les fichiers ici" styleClass="upload-title"/>
                                <Label text="Taille maximum : 50 Mo" styleClass="upload-subtitle"/>

                                <HBox spacing="10.0" alignment="CENTER">
                                    <children>
                                        <Button text="Télécharger un fichier"
                                                styleClass="secondary-button"/>
                                        <Button text="Télécharger à partir du cloud"
                                                styleClass="secondary-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- ANALYSE -->
                        <Label text="Analyse IA / fraude" styleClass="section-label"/>

                        <VBox spacing="10.0" styleClass="result-card">
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                            </padding>

                            <children>
                                <TextArea fx:id="feedbackArea"
                                          styleClass="feedback-area"
                                          editable="false"
                                          wrapText="true"
                                          prefHeight="170.0"/>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Back"
                                                onAction="#handleBack"
                                                styleClass="secondary-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
