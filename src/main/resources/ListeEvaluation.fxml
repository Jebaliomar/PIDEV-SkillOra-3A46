<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="720.0" prefWidth="1400.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ListeEvaluationController"
            styleClass="root">

    <children>

        <!-- =========================
             SIDEBAR GAUCHE
             ========================= -->
        <AnchorPane layoutX="0.0"
                    layoutY="0.0"
                    prefWidth="240.0"
                    prefHeight="720.0"
                    styleClass="sidebar">

            <children>
                <Label layoutX="35.0"
                       layoutY="45.0"
                       text="SkillORA"
                       styleClass="sidebar-logo" />



                <Button layoutX="18.0"
                        layoutY="160.0"
                        prefWidth="204.0"
                        prefHeight="48.0"
                        text="Evaluations"
                        styleClass="sidebar-button-active" />
            </children>
        </AnchorPane>

        <!-- =========================
             ZONE PRINCIPALE
             ========================= -->
        <AnchorPane layoutX="240.0"
                    layoutY="0.0"
                    prefWidth="1160.0"
                    prefHeight="720.0"
                    styleClass="main-content">

            <children>

                <!-- Header -->
                <Label layoutX="35.0"
                       layoutY="28.0"
                       text="Evaluations"
                       styleClass="label-title" />

                <Label layoutX="35.0"
                       layoutY="72.0"
                       text="Manage quizzes and exams"
                       styleClass="label-subtitle" />

                <Button layoutX="945.0"
                        layoutY="35.0"
                        prefWidth="170.0"
                        prefHeight="42.0"
                        text="+ Ajouter"
                        styleClass="button-primary"
                        onAction="#retourAjout" />

                <!-- Card centrale -->
                <AnchorPane layoutX="28.0"
                            layoutY="120.0"
                            prefHeight="550.0"
                            prefWidth="1100.0"
                            styleClass="card">

                    <children>
                        <Label layoutX="25.0"
                               layoutY="22.0"
                               text="All Evaluations"
                               styleClass="section-title" />

                        <TextField fx:id="searchField"
                                   layoutX="785.0"
                                   layoutY="20.0"
                                   prefWidth="285.0"
                                   prefHeight="42.0"
                                   promptText="Rechercher par mot-clé..."
                                   styleClass="search-field"
                                   onKeyReleased="#rechercherEvaluation" />

                        <TableView fx:id="evaluationTable"
                                   layoutX="25.0"
                                   layoutY="90.0"
                                   prefHeight="430.0"
                                   prefWidth="1045.0"
                                   styleClass="table-view">

                            <columns>
                                <TableColumn fx:id="titleCol" text="Title" prefWidth="190.0" />
                                <TableColumn fx:id="descriptionCol" text="Description" prefWidth="250.0" />
                                <TableColumn fx:id="typeCol" text="Type" prefWidth="120.0" />
                                <TableColumn fx:id="durationCol" text="Duration" prefWidth="120.0" />
                                <TableColumn fx:id="scoreCol" text="Score" prefWidth="100.0" />
                                <TableColumn fx:id="actionCol" text="Actions" prefWidth="265.0" />
                            </columns>
                        </TableView>
                    </children>
                </AnchorPane>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>