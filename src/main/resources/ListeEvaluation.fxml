<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="720.0" prefWidth="1400.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ListeEvaluationController"
            styleClass="root">

    <children>

        <AnchorPane layoutX="0.0"
                    layoutY="0.0"
                    prefWidth="240.0"
                    prefHeight="720.0"
                    styleClass="sidebar">

            <children>
                <Label layoutX="35.0"
                       layoutY="45.0"
                       text="SkillORA"
                       styleClass="sidebar-logo" />

                <Button layoutX="18.0"
                        layoutY="160.0"
                        prefWidth="204.0"
                        prefHeight="48.0"
                        text="Evaluations"
                        styleClass="sidebar-button-active" />
            </children>
        </AnchorPane>

        <AnchorPane layoutX="240.0"
                    layoutY="0.0"
                    prefWidth="1160.0"
                    prefHeight="720.0"
                    styleClass="main-content">

            <children>

                <Label layoutX="42.0"
                       layoutY="30.0"
                       text="Evaluations"
                       styleClass="label-title" />

                <Label layoutX="42.0"
                       layoutY="76.0"
                       text="Manage quizzes and exams"
                       styleClass="label-subtitle" />

                <Button layoutX="900.0"
                        layoutY="34.0"
                        prefWidth="180.0"
                        prefHeight="44.0"
                        text="+ Ajouter"
                        styleClass="button-primary"
                        onAction="#retourAjout" />

                <AnchorPane layoutX="26.0"
                            layoutY="128.0"
                            prefHeight="560.0"
                            prefWidth="1108.0"
                            styleClass="card">

                    <children>
                        <Label layoutX="32.0"
                               layoutY="26.0"
                               text="All Evaluations"
                               styleClass="section-title" />

                        <TextField fx:id="searchField"
                                   layoutX="430.0"
                                   layoutY="20.0"
                                   prefWidth="250.0"
                                   prefHeight="44.0"
                                   promptText="Rechercher par titre, description, type..."
                                   onKeyReleased="#handleSearch"
                                   styleClass="search-field" />

                        <ComboBox fx:id="typeFilterCombo"
                                  layoutX="830.0"
                                  layoutY="20.0"
                                  prefWidth="246.0"
                                  prefHeight="44.0"
                                  promptText="Filtrer par type"
                                  onAction="#filtrerParType"
                                  styleClass="search-field" />

                        <TableView fx:id="evaluationTable"
                                   layoutX="26.0"
                                   layoutY="84.0"
                                   prefHeight="448.0"
                                   prefWidth="1056.0"
                                   styleClass="table-view">

                            <columns>
                                <TableColumn fx:id="titleCol" text="Title" prefWidth="220.0" />
                                <TableColumn fx:id="descriptionCol" text="Description" prefWidth="330.0" />
                                <TableColumn fx:id="typeCol" text="Type" prefWidth="120.0" />
                                <TableColumn fx:id="durationCol" text="Duration" prefWidth="110.0" />
                                <TableColumn fx:id="scoreCol" text="Score" prefWidth="100.0" />
                                <TableColumn fx:id="actionCol" text="Actions" prefWidth="300.0" />
                            </columns>
                        </TableView>
                    </children>
                </AnchorPane>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>