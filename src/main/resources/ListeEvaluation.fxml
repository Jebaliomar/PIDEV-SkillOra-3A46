<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ListeEvaluationController">

    <children>
        <TableView fx:id="evaluationTable" layoutX="20.0" layoutY="20.0" prefHeight="400.0" prefWidth="860.0">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="titleCol" text="Title" prefWidth="140.0" />
                <TableColumn fx:id="descriptionCol" text="Description" prefWidth="200.0" />
                <TableColumn fx:id="typeCol" text="Type" prefWidth="100.0" />
                <TableColumn fx:id="durationCol" text="Duration" prefWidth="100.0" />
                <TableColumn fx:id="scoreCol" text="Total Score" prefWidth="120.0" />
            </columns>
        </TableView>

        <Button layoutX="20.0"
                layoutY="440.0"
                text="Retour"
                onAction="#retourAjout" />
    </children>
</AnchorPane>