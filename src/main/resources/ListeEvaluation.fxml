<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            stylesheets="@styles/style.css"
            styleClass="page-scroll"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ListeEvaluationController">
    <content>
        <VBox spacing="22" styleClass="module-page main-content-wrap">
            <padding>
                <Insets top="26" right="28" bottom="28" left="28"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Evaluations" styleClass="page-title"/>
                    <Label text="Manage quizzes, exams, AI generation, plagiarism checks, voice audio and hangman games."
                           styleClass="page-subtitle" wrapText="true"/>
                </VBox>

                <Button text="User View"
                        styleClass="btn-outline"
                        onAction="#ouvrirUserAssessmentView"/>
                <Button text="+ Add Evaluation"
                        styleClass="btn-primary"
                        onAction="#retourAjout"/>
            </HBox>

            <VBox spacing="16" styleClass="toolbar-card">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="All Evaluations" styleClass="card-title"/>
                        <Label text="Search and filter assessments before opening their advanced actions."
                               styleClass="card-subtitle"/>
                    </VBox>

                    <TextField fx:id="searchField"
                               prefWidth="320"
                               prefHeight="42"
                               promptText="Search title, description, type..."
                               onKeyReleased="#handleSearch"
                               styleClass="custom-text-field"/>

                    <ComboBox fx:id="typeFilterCombo"
                              prefWidth="240"
                              prefHeight="42"
                              promptText="Filter by type"
                              onAction="#filtrerParType"
                              styleClass="custom-text-field"/>
                </HBox>
            </VBox>

            <VBox spacing="0" styleClass="table-card">
                <TableView fx:id="evaluationTable"
                           prefHeight="520"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="titleCol" text="Title" prefWidth="220.0"/>
                        <TableColumn fx:id="descriptionCol" text="Description" prefWidth="330.0"/>
                        <TableColumn fx:id="typeCol" text="Type" prefWidth="120.0"/>
                        <TableColumn fx:id="durationCol" text="Duration" prefWidth="110.0"/>
                        <TableColumn fx:id="scoreCol" text="Score" prefWidth="100.0"/>
                        <TableColumn fx:id="actionCol" text="Actions" prefWidth="360.0"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <Region prefHeight="2"/>
        </VBox>
    </content>
</ScrollPane>
