<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1400.0" prefHeight="820.0"
            stylesheets="@styles/style.css,@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.QuizQuestionController"
            styleClass="root-bg">

    <left>
        <fx:include fx:id="adminSidebar" source="viewsadmin/common/AdminSidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="page-scroll">

            <content>
                <VBox spacing="24.0"
                      alignment="TOP_LEFT">

                    <padding>
                        <Insets top="24.0" right="28.0" bottom="28.0" left="28.0"/>
                    </padding>

                    <Label fx:id="pageTitleLabel"
                           text="Ajouter Question Quiz"
                           styleClass="page-title"/>

                    <AnchorPane prefHeight="980.0"
                                styleClass="create-card">

                        <children>
                            <TextField fx:id="idField" visible="false" managed="false"/>
                            <TextField fx:id="evaluationIdField" visible="false" managed="false"/>

                            <VBox layoutX="28.0"
                                  layoutY="26.0"
                                  prefWidth="1030.0"
                                  spacing="18.0">

                                <children>

                                    <Label fx:id="evaluationInfoLabel"
                                           text="Quiz"
                                           styleClass="label-subtitle"/>

                                    <HBox spacing="16.0">
                                        <children>
                                            <VBox spacing="8.0" prefWidth="920.0">
                                                <children>
                                                    <Label text="Sujet / Langage pour génération IA" styleClass="form-label"/>
                                                    <TextField fx:id="aiTopicField"
                                                               prefHeight="46.0"
                                                               promptText="Ex: Java, Python, Symfony, Spring Boot..."
                                                               styleClass="form-input"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="8.0" prefWidth="220.0">
                                                <children>
                                                    <Label text=" " styleClass="form-label"/>
                                                    <Button fx:id="btnGenerateAI"
                                                            text="Générer IA"
                                                            prefWidth="220.0"
                                                            prefHeight="46.0"
                                                            onAction="#genererParIA"
                                                            styleClass="button-primary"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <VBox spacing="8.0">
                                        <children>
                                            <Label text="Question" styleClass="form-label"/>
                                            <TextArea fx:id="contentField"
                                                      prefWidth="1240.0"
                                                      prefHeight="90.0"
                                                      wrapText="true"
                                                      styleClass="form-textarea"/>
                                            <Label fx:id="contentErrorLabel" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                        <children>
                                            <Label text="Explication" styleClass="form-label"/>
                                            <TextArea fx:id="explanationField"
                                                      prefWidth="1240.0"
                                                      prefHeight="80.0"
                                                      wrapText="true"
                                                      styleClass="form-textarea"/>
                                            <Label fx:id="explanationErrorLabel" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <HBox spacing="24.0">
                                        <children>

                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Type" styleClass="form-label"/>
                                                    <ComboBox fx:id="typeComboBox"
                                                              prefHeight="46.0"
                                                              promptText="Choisir type"
                                                              styleClass="form-combo"/>
                                                    <Label fx:id="typeErrorLabel" styleClass="error-label"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Score" styleClass="form-label"/>
                                                    <TextField fx:id="scoreField"
                                                               prefHeight="46.0"
                                                               styleClass="form-input"/>
                                                    <Label fx:id="scoreErrorLabel" styleClass="error-label"/>
                                                </children>
                                            </VBox>

                                        </children>
                                    </HBox>

                                    <HBox spacing="24.0">
                                        <children>
                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Option A" styleClass="form-label"/>
                                                    <TextField fx:id="optionAField"
                                                               prefHeight="46.0"
                                                               styleClass="form-input"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Option B" styleClass="form-label"/>
                                                    <TextField fx:id="optionBField"
                                                               prefHeight="46.0"
                                                               styleClass="form-input"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <HBox spacing="24.0">
                                        <children>
                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Option C" styleClass="form-label"/>
                                                    <TextField fx:id="optionCField"
                                                               prefHeight="46.0"
                                                               styleClass="form-input"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="8.0" prefWidth="608.0">
                                                <children>
                                                    <Label text="Option D" styleClass="form-label"/>
                                                    <TextField fx:id="optionDField"
                                                               prefHeight="46.0"
                                                               styleClass="form-input"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <HBox spacing="24.0">
                                        <children>
                                            <VBox spacing="8.0" prefWidth="300.0">
                                                <children>
                                                    <Label text="Bonne réponse" styleClass="form-label"/>
                                                    <ComboBox fx:id="correctAnswerCombo"
                                                              prefWidth="300.0"
                                                              prefHeight="46.0"
                                                              promptText="A / B / C / D"
                                                              styleClass="form-combo"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <Label fx:id="optionErrorLabel" styleClass="error-label"/>

                                    <HBox spacing="14.0">
                                        <children>
                                            <Button fx:id="btnAjouter"
                                                    text="Save"
                                                    prefWidth="118.0"
                                                    prefHeight="46.0"
                                                    onAction="#ajouterQuestion"
                                                    styleClass="button-save"/>

                                            <Button fx:id="btnModifier"
                                                    text="Update"
                                                    prefWidth="118.0"
                                                    prefHeight="46.0"
                                                    onAction="#modifierQuestion"
                                                    styleClass="button-save"
                                                    visible="false"
                                                    managed="false"/>

                                            <Button text="Cancel"
                                                    prefWidth="118.0"
                                                    prefHeight="46.0"
                                                    onAction="#viderChamps"
                                                    styleClass="button-cancel"/>

                                            <Button text="Retour Liste"
                                                    prefWidth="150.0"
                                                    prefHeight="46.0"
                                                    onAction="#retourListeQuestions"
                                                    styleClass="button-secondary"/>
                                        </children>
                                    </HBox>

                                </children>
                            </VBox>
                        </children>
                    </AnchorPane>
                </VBox>
            </content>
        </ScrollPane>

    </center>
</BorderPane>
