<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.SiteSalleDetailController"
            prefWidth="1440" prefHeight="900" styleClass="site-root">

    <top>
        <fx:include fx:id="navbar" source="../../views/front/common/SkilloraNavbar.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="site-scroll">
            <content>
                <VBox spacing="30" styleClass="site-content site-salle-page">
                    <padding>
                        <Insets top="30" right="42" bottom="42" left="42"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="28" styleClass="site-detail-hero-card site-detail-hero-card-refined">
                        <padding>
                            <Insets top="28" right="28" bottom="28" left="28"/>
                        </padding>

                        <StackPane prefWidth="380" prefHeight="270" styleClass="site-cover-shell">
                            <ImageView fx:id="coverImageView" fitWidth="380" fitHeight="270" preserveRatio="false" smooth="true" visible="false" managed="false"/>
                            <StackPane fx:id="coverFallbackPane" styleClass="site-cover-fallback">
                                <VBox alignment="CENTER" spacing="10">
                                    <Label text="Salle" styleClass="site-cover-title"/>
                                    <Label text="Public detail view" styleClass="site-cover-copy"/>
                                </VBox>
                            </StackPane>
                            <VBox alignment="BOTTOM_LEFT" spacing="4" styleClass="site-cover-overlay" StackPane.alignment="BOTTOM_LEFT">
                                <Label text="SkillORA Space" styleClass="site-cover-overlay-title"/>
                                <Label text="Room detail and seat map" styleClass="site-cover-overlay-copy"/>
                            </VBox>
                        </StackPane>

                        <VBox spacing="18" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="SALLE DETAIL" styleClass="site-detail-eyebrow"/>
                                <Label text="Live seat selection" styleClass="site-detail-status-chip"/>
                            </HBox>
                            <Label fx:id="heroTitleLabel" text="Salle" styleClass="site-salle-detail-title"/>
                            <Label text="Review the room, complete the Snake challenge, then choose available seats before creating your reservation."
                                   wrapText="true" styleClass="site-salle-hero-subtitle"/>

                            <HBox spacing="14" styleClass="site-hero-summary-row">
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="site-summary-box">
                                    <Label text="Linked Event" styleClass="site-detail-key"/>
                                    <Button fx:id="eventLinkButton" text="-" onAction="#onBackToEvents" styleClass="site-event-link"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="site-summary-box">
                                    <Label text="Location" styleClass="site-detail-key"/>
                                    <Label fx:id="locationLabel" text="-" styleClass="site-detail-value"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="14" styleClass="site-hero-stats-row">
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="site-stat-box">
                                    <Label text="Duration" styleClass="site-detail-key"/>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Label fx:id="durationValueLabel" text="0" styleClass="site-detail-value-strong"/>
                                        <Label text="min" styleClass="site-detail-value"/>
                                    </HBox>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="site-stat-box">
                                    <Label text="Capacity" styleClass="site-detail-key"/>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Label fx:id="capacityValueLabel" text="0" styleClass="site-detail-value-strong"/>
                                        <Label text="seats" styleClass="site-detail-value"/>
                                    </HBox>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="site-stat-box">
                                    <Label text="Pricing" styleClass="site-detail-key"/>
                                    <Label fx:id="priceLabel" text="-" styleClass="site-detail-value"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox spacing="24" styleClass="site-detail-body">
                        <VBox spacing="22" prefWidth="790" HBox.hgrow="ALWAYS" styleClass="site-salle-card site-model-card">
                            <padding>
                                <Insets top="24" right="24" bottom="24" left="24"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <VBox spacing="4">
                                    <Label text="Salle Details" styleClass="site-salle-card-title"/>
                                    <Label text="Equipment and playable room challenge." styleClass="site-card-subtitle"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="open3dViewerButton" text="Open 3D viewer" onAction="#onShow3dViewer" styleClass="site-outline-chip"/>
                                <Button fx:id="playSnakeButton" text="Play Snake Game" onAction="#onShowSnakeGame" visible="false" managed="false" styleClass="site-outline-chip"/>
                                <Button fx:id="snakeStartButton" text="Start Game" onAction="#onStartSnakeGame" styleClass="site-outline-chip"/>
                                <Button fx:id="snakeRestartButton" text="Restart" onAction="#onRestartSnakeGame" styleClass="site-outline-chip"/>
                            </HBox>

                            <Region prefHeight="1" styleClass="site-detail-divider"/>

                            <VBox spacing="12" styleClass="site-equipment-panel">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Equipment" styleClass="site-detail-key"/>
                                    <Label text="Included in this room" styleClass="site-muted-pill"/>
                                </HBox>
                                <FlowPane fx:id="equipmentFlow" hgap="8" vgap="8" prefWrapLength="700"/>
                            </VBox>

                            <VBox spacing="16">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <VBox spacing="4">
                                        <Label fx:id="viewerTitleLabel" text="Snake Challenge" styleClass="site-salle-card-title"/>
                                        <Label fx:id="viewerSubtitleLabel" text="Complete 30 levels without losing to unlock the gift QR code." styleClass="site-card-subtitle"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="snakeLevelLabel" text="Level: 1 / 30" styleClass="site-viewer-chip"/>
                                    <Label fx:id="snakeScoreLabel" text="Score: 0 | Food: 0 / 3" styleClass="site-snake-score-chip"/>
                                    <Button fx:id="modelCloseButton" text="X" onAction="#onShowSnakeGame" visible="false" managed="false" styleClass="site-model-close-button"/>
                                </HBox>

                                <StackPane fx:id="viewerFrame" prefHeight="440" styleClass="site-snake-frame">
                                    <StackPane fx:id="snakeFrame" alignment="CENTER" styleClass="site-snake-playfield">
                                        <Canvas fx:id="snakeCanvas" width="720" height="400" focusTraversable="true" StackPane.alignment="CENTER"/>
                                        <VBox fx:id="snakeOverlay" alignment="CENTER" spacing="14" styleClass="site-snake-overlay" StackPane.alignment="CENTER">
                                            <Label fx:id="snakeOverlayTitle" text="Snake Challenge" styleClass="site-snake-overlay-title"/>
                                            <Label fx:id="snakeOverlayMessage" text="Use arrows or ZQSD to move. Clear all 30 levels without losing." wrapText="true" styleClass="site-snake-overlay-copy"/>
                                            <HBox alignment="CENTER" spacing="10">
                                                <Button fx:id="snakeOverlayStartButton" text="Start Game" onAction="#onStartSnakeGame" styleClass="site-snake-primary-button"/>
                                                <Button fx:id="snakeOverlayRestartButton" text="Restart" onAction="#onRestartSnakeGame" styleClass="site-snake-secondary-button"/>
                                            </HBox>
                                    </VBox>
                                    <VBox fx:id="snakeRewardPane" managed="false" visible="false" alignment="CENTER" spacing="12" styleClass="site-snake-reward-pane" StackPane.alignment="CENTER">
                                        <Label text="🎁 Reward Unlocked!" styleClass="site-snake-reward-title"/>
                                        <Label text="Scan this QR code to claim your gift." wrapText="true" styleClass="site-snake-reward-copy"/>
                                        <ImageView fx:id="rewardQrImageView" fitWidth="172" fitHeight="172" preserveRatio="true" smooth="false" styleClass="site-snake-reward-qr"/>
                                        <Button text="Continue Game" onAction="#onContinueSnakeReward" styleClass="site-snake-primary-button"/>
                                    </VBox>
                                    </StackPane>
                                    <StackPane fx:id="modelFrame" managed="false" visible="false" styleClass="site-embedded-model-pane">
                                        <WebView fx:id="modelWebView" prefHeight="416" prefWidth="720" visible="false" managed="false"/>
                                        <VBox fx:id="modelPlaceholderBox" alignment="CENTER" spacing="14" styleClass="site-model-placeholder">
                                            <StackPane prefWidth="84" prefHeight="84" styleClass="site-model-badge">
                                                <Label text="3D" styleClass="site-model-badge-text"/>
                                            </StackPane>
                                            <Label fx:id="modelStatusTitle" text="No 3D model available" styleClass="site-model-status-title"/>
                                            <Label fx:id="modelStatusSubtitle" text="This salle does not have a valid .glb or .gltf model yet." styleClass="site-model-status-subtitle" wrapText="true"/>
                                        </VBox>
                                    </StackPane>
                                </StackPane>
                            </VBox>

                            <VBox spacing="12" styleClass="site-roulette-card">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <VBox spacing="4">
                                        <Label text="Roulette Reward" styleClass="site-salle-card-title"/>
                                        <Label text="Choose a number, then spin for a chance to unlock a SkillORA gift." styleClass="site-card-subtitle"/>
                                    </VBox>
                                </HBox>
                                <WebView fx:id="rouletteWebView" prefHeight="500" minHeight="480" prefWidth="720"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="22" prefWidth="510" minWidth="470" styleClass="site-salle-card site-seat-card">
                            <padding>
                                <Insets top="24" right="24" bottom="24" left="24"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="4">
                                    <Label text="Capacity Matrix" styleClass="site-salle-card-title"/>
                                    <Label text="Pick one or more available seats." styleClass="site-card-subtitle"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="seatsSummaryLabel" text="Capacity matrix 0 seats" styleClass="site-matrix-caption"/>
                            </HBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="site-seat-action-row">
                                <Label text="Selection required" styleClass="site-seat-helper-pill"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Test Vision" onAction="#onOpenVisionTest" styleClass="site-vision-test-button"/>
                                <Button fx:id="reservationButton" text="Reservation" onAction="#onOpenReservationForm" styleClass="site-submit-button"/>
                            </HBox>

                            <HBox spacing="14">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="site-legend-item">
                                    <StackPane styleClass="site-legend-swatch site-legend-available"/>
                                    <Label text="Available" styleClass="site-legend-text"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="site-legend-item">
                                    <StackPane styleClass="site-legend-swatch site-legend-reserved"/>
                                    <Label text="Reserved" styleClass="site-legend-text"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="site-legend-item">
                                    <StackPane styleClass="site-legend-swatch site-legend-selected"/>
                                    <Label text="Selected" styleClass="site-legend-text"/>
                                </HBox>
                            </HBox>

                            <GridPane hgap="14" vgap="14">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.333"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.333"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.333"/>
                                </columnConstraints>
                                <VBox spacing="6" styleClass="site-seat-stat-card" GridPane.columnIndex="0">
                                    <Label fx:id="availableCountLabel" text="0" styleClass="site-seat-stat-value"/>
                                    <Label text="Available" styleClass="site-seat-stat-label"/>
                                </VBox>
                                <VBox spacing="6" styleClass="site-seat-stat-card" GridPane.columnIndex="1">
                                    <Label fx:id="reservedCountLabel" text="0" styleClass="site-seat-stat-value"/>
                                    <Label text="Reserved" styleClass="site-seat-stat-label"/>
                                </VBox>
                                <VBox spacing="6" styleClass="site-seat-stat-card" GridPane.columnIndex="2">
                                    <Label fx:id="selectedCountLabel" text="0" styleClass="site-seat-stat-value"/>
                                    <Label text="Selected" styleClass="site-seat-stat-label"/>
                                </VBox>
                            </GridPane>

                            <StackPane styleClass="site-seat-grid-shell" VBox.vgrow="ALWAYS">
                                <GridPane fx:id="seatsGrid" hgap="10" vgap="10" styleClass="site-seat-grid"/>
                            </StackPane>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
